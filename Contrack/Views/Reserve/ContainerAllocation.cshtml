@model Contrack.ContainerAllocation
@using Contrack;
@{
    ViewBag.Title = "Container Allocation";
    ViewBag.MainManu = "Booking";
    ViewBag.SubManu = "Allocation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="~/css/Booking/booking.css?v=1.0.2" rel="stylesheet" />
<link href="~/css/Booking/allocation.css?v=1.0.0" rel="stylesheet" />
@{
    int requiredcount = Model.Container.qty;
    int selectedcount = Model.Allocations.Sum(x => x.Models.Sum(y => y.SelectedCount));
    int remaingcount = requiredcount - selectedcount;
    decimal percentage = requiredcount == 0 ? 0 : ((decimal)selectedcount / requiredcount) * 100;

    int currentindex = Model.Booking.details.FindIndex(x => x.bookingdetailuuid == Model.Container.bookingdetailuuid);
    ContainerBookingDetailDTO previouscontainer = null;
    ContainerBookingDetailDTO nextcontainer = null;
    if (currentindex > 0)
    {
        previouscontainer = Model.Booking.details[currentindex - 1];
    }
    if (currentindex < Model.Booking.details.Count - 1)
    {
        nextcontainer = Model.Booking.details[currentindex + 1];
    }
}
@Html.Partial("_BookingHeader", Model.Booking.bookinguuid)

<div class="container-fluid nobottom">
    <div class="booking-section  flex flex-col">
        <div class="booking-info">
            <div class="booking-max-width">
                <div class="booking-content">
                    @*<div class="flex justify-between">
                            <div class="page-header-holder">
                                <span class=" page-header">Container Allocation</span>
                                <span class="subhead">Allocate containers based on available locations and equipment models.</span>
                            </div>
                            <button class="btn btn-md text-md btn-outline only-outline btn-primary">Booking Summary</button>
                        </div>*@
                    <div class="page-header-holder">
                        <span class="head">Container Allocation</span>
                        <span class="subhead">Allocate containers based on available locations and equipment models.</span>
                    </div>
                    <div class="left-section">
                        <div class="allocation-section">
                            @if (Model.Allocations.Count == 0)
                            {
                                <div class="w-full">
                                    @Html.Partial("_EmptyTable", new EmptyTable
                               {
                                   Heading = "No containers available to allocate",
                                   SubHead = "Add a container for the required model in required location.",
                                   Icon = "<img src='/assets/img/container-empty.svg'/>",
                               })
                                </div>
                            }
                            else
                            {
                                <div class="allocation-cards">
                                    @Html.HiddenFor(m => m.Container.bookingdetailid.EncryptedValue, new { @id = "bookingdetailid" })
                                    @Html.HiddenFor(m => m.Container.bookingid.EncryptedValue, new { @id = "bookingid" })

                                    @for (int i = 0; i < Model.Allocations.Count; i++)
                                    {
                                        <div class="allocation-card">
                                            @Html.HiddenFor(m => m.Allocations[i].LocationId.EncryptedValue, new { @class = "LocationId" })
                                            <div class="allocation-card-header">
                                                <img src="~/assets/Flags/74_IN.png" />
                                                <span class="port-group">
                                                    <span class="port-name">
                                                        @Model.Allocations[i].LocationName (@Model.Allocations[i].LocationType)
                                                    </span>
                                                    <span class="port-country">
                                                        <span class="port-country-name">
                                                            @Model.Allocations[i].PortName
                                                        </span>
                                                        <span class="dot"></span>
                                                        <span class="port-terminal">
                                                            @Model.Allocations[i].CountryName
                                                        </span>
                                                    </span>
                                                </span>
                                            </div>
                                            <div class="allocation-card-body">
                                                @for (int j = 0; j < Model.Allocations[i].Models.Count; j++)
                                                {
                                                    <div class="model-card @(Model.Allocations[i].Models[j].AvailableCount >= Model.Container.qty ? "available" : "critical")">
                                                        @Html.HiddenFor(m => m.Allocations[i].Models[j].ContainerModelId.EncryptedValue, new { @class = "ContainerModelId" })
                                                        @Html.HiddenFor(m => m.Allocations[i].Models[j].ReservationID.EncryptedValue, new { @class = "ReservationID" })
                                                        <div class="model-card-info">
                                                            <div class="model-card-info-detail">
                                                                <span class="model-card-name">
                                                                    @(Model.Allocations[i].Models[j].ContainerSizeName + " " + Model.Allocations[i].Models[j].ContainerTypeName)
                                                                </span>
                                                                <span class="model-card-iso">
                                                                    ISO: @Model.Allocations[i].Models[j].ContainerModelIso
                                                                </span>
                                                            </div>
                                                            <div class="model-card-info-counts">
                                                                <div class="count-item @(@Model.Allocations[i].Models[j].AvailableCount > 0 ? "available" : "gray")">
                                                                    <div class="count-text">
                                                                        <span class="count-text-label">Available</span>
                                                                        <span class="count-text-count">@Model.Allocations[i].Models[j].AvailableCount</span>
                                                                    </div>
                                                                    @*<div class="count-icon">
                                                                            <img src="~/assets/img/greentick.png" />
                                                                        </div>*@
                                                                </div>

                                                                <div class="count-item gray">
                                                                    <div class="count-text">
                                                                        <span class="count-text-label">Blocked</span>
                                                                        <span class="count-text-count"><span>@Model.Allocations[i].Models[j].SelectedCount of</span> @Model.Allocations[i].Models[j].BlockedCount</span>
                                                                    </div>
                                                                    @*<div class="count-icon">
                                                                            <img src="~/assets/img/redclose.png" />
                                                                        </div>*@
                                                                </div>
                                                                <div class="count-item gray">
                                                                    <div class="count-text">
                                                                        <span class="count-text-label">Coming Soon</span>
                                                                        <span class="count-text-count">@Model.Allocations[i].Models[j].ComingSoon</span>
                                                                    </div>
                                                                    @*<div class="count-icon">
                                                                            <img src="~/assets/img/yellowwait.png" />
                                                                        </div>*@
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="model-card-action">
                                                            @if (Model.Allocations[i].Models[j].SelectedCount > 0)
                                                            {
                                                                <button onclick="DeleteAllocateQty(this);" class="btn btn-md text-sm btn-outline btn-danger">
                                                                    <i class="ki-filled ki-trash"></i>
                                                                    Remove (@Model.Allocations[i].Models[j].SelectedCount Qty)
                                                                </button>
                                                            }
                                                            else if (Model.Allocations[i].Models[j].AvailableCount == 0)
                                                            {
                                                                <button disabled class="btn btn-md text-sm btn-light">
                                                                    Out of Stock
                                                                </button>
                                                            }
                                                            else if (remaingcount == 0)
                                                            {
                                                                <button disabled type="button" class="btn btn-md text-sm btn-primary">
                                                                    Allocate
                                                                </button>
                                                            }
                                                            else if (Model.Allocations[i].Models[j].AvailableCount > 0)
                                                            {
                                                                @Html.TextBoxFor(m => m.Allocations[i].Models[j].SelectedCount, new { @class = "input SelectedCount", @placeholder = "0", @datarequired = "no", @data_max = Math.Min(Model.Allocations[i].Models[j].AvailableCount, remaingcount) })
                                                                <button onclick="AllocateQty(this);" type="button" class="btn btn-md text-sm btn-primary">
                                                                    Allocate
                                                                </button>
                                                            }
                                                            else
                                                            {
                                                                <button disabled class="btn btn-sm text-sm btn-light">
                                                                    Out of Stock
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>
                                                }

                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Persistent Booking Summary on the side -->
        <div class="booking-summary no-bg">
            <div class="summary-content">
                <div class="allocation-section">
                    <div class="allocation-summary">
                        @*<span class="summary-title">Allocation Summary:</span>*@
                        @{
                            string cssclass = "";
                            if (remaingcount == 0)
                            {
                                cssclass = "green";
                            }
                            else if (selectedcount > 0)
                            {
                                cssclass = "red";
                            }
                        }

                        <div class="requirement @cssclass">
                            <img src="~/assets/img/container-half.svg" class="corner-logo" />
                            <span class="heading">Container allocation (@(currentindex + 1) of @Model.Booking.details.Count)</span>
                            <div class="container-info">
                                <div class="info-section">
                                    <div class="avatar">
                                        <img src="~/assets/img/container-wh.svg" />
                                    </div>
                                    <div class="info-item">
                                        <span class="type-size">
                                            @Model.Container.sizename @Model.Container.containertypename (@(string.IsNullOrEmpty(Model.Container.containermodeluuid) ? "ISO : Any" : "ISO : " + Model.Container.isocode))
                                        </span>
                                        <span class="qty">
                                            Required Qty : @requiredcount
                                        </span>
                                    </div>
                                </div>
                                <div class="progress-section">
                                    <span class="qty-remain">
                                        @selectedcount of @requiredcount
                                    </span>
                                    <div class="progress">
                                        <div class="progress-bar" style="width: @percentage%"></div>
                                    </div>

                                </div>
                            </div>
                        </div>
                        @{
                            var SelectedList = Model.Allocations
                                        .SelectMany(location => location.Models
                                            .Where(model => model.SelectedCount > 0)
                                            .Select(model => new
                                            {
                                                ModelISO = model.ContainerModelIso,
                                                LocationName = location.LocationName,
                                                Qty = model.SelectedCount
                                            })
                                        ).ToList();
                        }

                        <div class="selected-list">
                            <div class="header">
                                <span class="head-text">Allocated Units:</span>
                                <span class="head-count">@selectedcount of @requiredcount Selected</span>
                            </div>
                            <div class="body">
                                @if (SelectedList.Count > 0)
                                {
                                    foreach (var item in SelectedList)
                                    {
                                        <div class="item">
                                            <i class="ki-filled ki-logistic"></i>
                                            <div class="item-info">
                                                <div class="item-info-text">
                                                    <span class="head">ISO : @item.ModelISO</span>
                                                    <span class="subhead">@item.LocationName</span>
                                                </div>
                                                <div class="item-info-qty">
                                                    <span class="head">@item.Qty</span>
                                                    <span class="subhead">Qty</span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    @*<div class="item">
                                            No Units allocated
                                        </div>*@
                                    <div class="empty-card noshadow">
                                        <div class="inner">
                                            <div class="emptyicon">
                                                <img src='/assets/img/container-empty.svg' />
                                            </div>
                                            <h2 class="heading">
                                                No Units allocated
                                            </h2>
                                            <span class="subheading">
                                                You haven’t allocated any units for this container type yet.
                                            </span>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="action">
                                <div class="flex flex-col justify-center gap-3">
                                    <div class="flex justify-between gap-3">
                                        @if (previouscontainer != null)
                                        {
                                            <a style="flex:1;" href="@Url.Action("ContainerAllocation", "Reserve", new { refid = Model.Booking.bookinguuid, bookingdetailuuid = previouscontainer.bookingdetailuuid })" class="btn gap-3 btn-gray actionbutton">
                                                <i class="ki-filled ki-arrow-left"></i>
                                                Back to @previouscontainer.sizename @previouscontainer.containertypename
                                            </a>
                                        }
                                        else
                                        {
                                            <a style="flex:1;" href="@Url.Action("FinalSummary", "Booking", new { refid = Model.Booking.bookinguuid })"
                                               class="btn btn-gray actionbutton">
                                                Back to Preview
                                            </a>
                                        }

                                    </div>
                                    @if (nextcontainer != null)
                                    {
                                        <a href="@Url.Action("ContainerAllocation", "Reserve", new { refid = Model.Booking.bookinguuid, bookingdetailuuid = nextcontainer.bookingdetailuuid })" class="btn btn-primary actionbutton" id="btnCustomerSelection">
                                            Next : @nextcontainer.sizename @nextcontainer.containertypename
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="@Url.Action("ContainerSelection", "Reserve", new { refid = Model.Booking.bookinguuid })" class="btn btn-primary actionbutton" id="btnCustomerSelection">
                                            Next : Unit Assignment
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            @*<div class="summary-footer">

                </div>*@
        </div>
    </div>
</div>

@section PageScripts {
    <script src="~/js/ContainerBooking/allocation.js?v=1.0.0"></script>
}