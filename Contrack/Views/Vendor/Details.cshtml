@using Contrack;
@model Contrack.Vendor
@{
    ViewBag.Title = "Vendor";
    ViewBag.MainManu = "Vendors";
    ViewBag.SubManu = "VendorInfo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="mb-5 lg:mb-7.5">
    <!-- Container -->
    <div class="container-fluid flex items-center justify-between flex-wrap gap-5">
        <div class="flex flex-col justify-center items-start flex-wrap gap-1 lg:gap-2">
            <h1 class="font-medium text-lg text-gray-900">
                @Html.Partial("_GoBack") Vendor Info
            </h1>
            <div class="flex items-center gap-1 text-sm font-normal">
                <span class="text-gray-700">
                    Masters
                </span>
                <span class="text-gray-400 text-sm">
                    /
                </span>
                <a href="@Url.Action("Details","Vendor")" class="text-gray-700 hover:text-primary">
                    Vendors
                </a>
                <span class="text-gray-400 text-sm">
                    /
                </span>
                <span class="text-gray-900">
                    Vendor Info
                </span>
            </div>
        </div>

    </div>
    <!-- End of Container -->
</div>
@if (Model.vendor?.vendorid?.NumericValue == 0)
{
    @Html.Partial("~/Views/Shared/Masters/_MasterNotFound.cshtml", new NotFound()
    {
    Message = "Vendor not found",
    ReturnURL = Url.Action("List", "Vendor"),
    ReturnButton = "Vendors"
    })
}
else
{
    <div class="container-fluid w-full flex px-0">
        <!-- Content -->
        <main class="flex flex-col grow" id="content" role="content">
            <!-- Container -->
            @Html.Partial("~/Views/Master/Vendor/_VendorInfoHeader.cshtml", Model)a


            <div class="container-fluid">
                <div class="flex items-center flex-wrap md:flex-nowrap lg:items-end justify-between border-b border-b-gray-200 dark:border-b-coal-100 gap-3 lg:gap-6 mb-5 lg:mb-5">
                    @Html.Partial("~/Views/Master/Vendor/_VendorHeaderMenu.cshtml", Model)

                    <div class="flex items-center justify-end grow lg:grow-0 lg:pb-4 gap-2.5 mb-3 lg:mb-0">
                        <a href="@Url.Action("List","Vendor")" class="btn btn-xs btn-sm btn-light">
                            <i class="ki-filled ki-arrow-left">
                            </i>
                            Back to Vendors List
                        </a>

                        <button class="dropdown-toggle btn btn-sm btn-primary" onclick="OpenVendorModal('@Model.vendor.vendoruuid');">
                            <i class="ki-filled ki-notepad-edit">
                            </i>
                            Edit Vendor
                        </button>

                    </div>
                </div>
            </div>

            <!-- End of Container -->
            <!-- Container -->
            <div class="container-fluid">
                <!-- begin: grid -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 lg:gap-5">
                    <div class="col-span-1">
                        <div class="grid gap-5 lg:gap-5">
                            <div class="card shadow-none1 min-w-full">
                                <div class="card-header p-3">
                                    <h3 class="card-title">
                                        Vendor Info
                                    </h3>
                                </div>
                                <div class="card-body p-0">
                                    <div class="card-table scrollable-x-auto pb-3">
                                        <table class="table align-middle text-sm text-gray-500">
                                            <tbody>

                                                <tr>
                                                    @Html.Raw(Common.DisplayInfoTableWithAddEdit("Name", Model.vendor.legalname, "javascript:void(0);", "OpenVendorModal(\"" + Model.vendor.vendoruuid + "\");", Model.menus.edit))
                                                </tr>
                                                <tr>
                                                    @Html.Raw(Common.DisplayInfoTableWithAddEdit("Vendor Code", Model.vendor.vendorcode, "javascript:void(0);", "OpenVendorModal(\"" + Model.vendor.vendoruuid + "\");", Model.menus.edit))
                                                </tr>
                                                <tr>
                                                    <td class="py-3">Created For</td>
                                                    <td class="py-3 text-gray-700 text-sm font-medium">

                                                        @if (Model.vendor.agency?.agencyid?.NumericValue > 0)
                                                        {
                                                            <div class="flex items-center gap-4">
                                                                <div class="leading-none w-5 shrink-0">
                                                                    <i class="ki-filled ki-users text-warning text-2xl"></i>
                                                                </div>
                                                                <div class="flex flex-col gap-0.5">

                                                                    <span class="leading-none font-medium text-sm text-gray-900">Agency</span>
                                                                    <span class="text-2sm text-gray-700 font-normal">@Model.vendor.agency.agencyname</span>
                                                                </div>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="flex items-center gap-4">
                                                                <div class="leading-none w-5 shrink-0">
                                                                    <i class="ki-filled ki-people text-primary text-2xl"></i>
                                                                </div>
                                                                <div class="flex flex-col gap-0.5">

                                                                    <span class="leading-none font-medium text-sm text-gray-900">Hub</span>
                                                                    <span class="text-2sm text-gray-700 font-normal">@Model.vendor.agency.agencyname</span>
                                                                </div>
                                                            </div>

                                                        }


                                                    </td>

                                                    <td class="py-3 text-right">
                                                        <a class="btn btn-sm btn-icon btn-clear btn-primary" href="javascript:void(0);" onclick="OpenVendorModal('@Model.vendor.vendoruuid');"><i class="ki-filled ki-notepad-edit"></i></a>
                                                    </td>

                                                </tr>
                                                <tr>
                                                    @Html.Raw(Common.DisplayInfoTableWithAddEdit("Email", Model.vendor.contactemail.Replace(";", "<br/>"), "javascript:void(0);", "OpenVendorModal(\"" + Model.vendor.vendoruuid + "\");", Model.menus.edit))
                                                </tr>
                                                <tr>
                                                    @Html.Raw(Common.DisplayInfoTableWithAddEdit("Accounts Email", Model.vendor.accountsemail.Replace(";", "<br/>"), "javascript:void(0);", "OpenVendorModal(\"" + Model.vendor.vendoruuid + "\");", Model.menus.edit))
                                                </tr>
                                                <tr>
                                                    @Html.Raw(Common.DisplayInfoTableWithAddEdit("Address", Model.vendor.registeredaddress.Replace("\n", "<br/>"), "javascript:void(0);", "OpenVendorModal(\"" + Model.vendor.vendoruuid + "\");", Model.menus.edit))
                                                </tr>
                                                <tr>
                                                    @Html.Raw(Common.DisplayInfoTableWithAddEdit("Billing Address", Model.vendor.billingaddress.Replace("\n", "<br/>"), "javascript:void(0);", "OpenVendorModal(\"" + Model.vendor.vendoruuid + "\");", Model.menus.edit))
                                                </tr>
                                                <tr>
                                                    @Html.Raw(Common.DisplayInfoTableWithAddEdit("Phone", Model.vendor.phone, "javascript:void(0);", "OpenVendorModal(\"" + Model.vendor.vendoruuid + "\");", Model.menus.edit))
                                                </tr>

                                                <tr>
                                                    @Html.Raw(Common.DisplayInfoTableWithAddEdit("Preferred Currency", Model.vendor.preferredcurrency.Replace("\n", "<br/>"), "javascript:void(0);", "OpenVendorModal(\"" + Model.vendor.vendoruuid + "\");", Model.menus.edit))
                                                </tr>
                                                <tr>
                                                    @Html.Raw(Common.DisplayInfoTableWithAddEdit("Payment Terms", Model.vendor.paymentterms.ToString() + " Days", "javascript:void(0);", "OpenVendorModal(\"" + Model.vendor.vendoruuid + "\");", Model.menus.edit))
                                                </tr>
                                                <tr>
                                                    @Html.Raw(Common.DisplayInfoTableWithAddEdit("Standing Instructions", Model.vendor.standinginstructions.Replace("\n", "<br/>"), "javascript:void(0);", "OpenVendorModal(\"" + Model.vendor.vendoruuid + "\");", Model.menus.edit))
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            <div class="card shadow-none1 min-w-full" id="section_vendor_customattribute">
                                @Html.Partial("~/Views/Shared/Masters/Vendor/_VendorCustomAtrributes.cshtml", Model)
                            </div>

                        </div>
                    </div>
                    <div class="flex flex-col gap-5">
                        <div id="section_vendor_bankaccount">
                            @Html.Partial("~/Views/Shared/Masters/Vendor/_VendorBankAccounts.cshtml", Model)
                        </div>
                        <div id="section_vendor_contacts">
                            @Html.Partial("~/Views/Master/Vendor/_VendorContacts.cshtml", Model)
                        </div>
                        @*<div id="section_client_Address">
                                @Html.Partial("Client/_ClientAddress", Model)
                            </div>*@
                    </div>
                </div>
                <!-- end: grid -->
            </div>
            <!-- End of Container -->

        </main>
        <!-- End of Content -->
    </div>
}

<div id="modalsection">
</div>
@section PageScripts
{
    <script src="~/js/Masters/vendors.js?v=1.0.2"></script>
    <script src="~/js/Masters/vendorcontact.js?v=1.0.1"></script>
}