                    <span class="heading">Half height container</span>
                    <span class="subheading flex">
                        <span>
                            05 Models
                        </span>
                        <span class="badge badge-dot size-1 bg-gray-500">
                        </span>
                        <span>
                            23 Containers
                        </span>
                    </span>
                </div>
            </div>

            <div class="type-card flex flex-col">
                <img src="~/assets/icons/container.svg" />
                <div class="info flex flex-col">
                    <span class="heading">
                        Open side storage container
                    </span>
                    <span class="subheading flex">
                        <span>
