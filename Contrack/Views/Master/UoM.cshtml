@{
    ViewBag.Title = "UOM";
    ViewBag.MainManu = "More";
    ViewBag.SubManu = "UOM";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@Html.Partial("_MoreOptions")
<div class="mb-5 lg:mb-7.5">
    <div class="container-fluid flex items-center justify-between flex-wrap gap-5">
        <div class="flex flex-col justify-center items-start flex-wrap gap-1 lg:gap-2">
            <h1 class="font-medium text-lg text-gray-900">
                UOM
            </h1>
            <div class="flex items-center gap-1 text-sm font-normal">
                <span class="text-gray-700">Home</span>
                <span class="text-gray-400 text-sm">/</span>
                <span class="text-gray-700">Masters</span>
                <span class="text-gray-400 text-sm">/</span>
                <span class="text-gray-900">UOM</span>
            </div>
        </div>
        <div class="flex items-center flex-wrap gap-1.5 lg:gap-3.5">
            <button class="btn btn-sm btn-primary" onclick="OpenUoMModal()">
                <i class="ki-filled ki-plus"></i>
                Add UOM
            </button>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="card card-grid min-w-full">
        <div class="card-header flex-wrap gap-2">
            <h3 class="card-title font-medium text-sm">
                UOM List
            </h3>
            <div class="flex">
                <label class="input input-sm">
                    <i class="ki-filled ki-magnifier"></i>
                    <input data-datatable-search="#TableUnitofMeasure" placeholder="Search" type="text" value="">
                </label>
            </div>
        </div>
        <div class="card-body">
            <div id="TableUnitofMeasure">
                <div class="scrollable-x-auto">
                    <table class="table table-auto table-border align-middle text-gray-700 font-medium text-sm" data-datatable-table="true">
                        <thead>
                            <tr>
                                <th class="min-w-[250px]" data-datatable-column="uomname">
                                    <span class="sort">
                                        <span class="sort-label">UOM</span>
                                        <span class="sort-icon"></span>
                                    </span>
                                </th>
                                <th class="w-[150px] text-center" nowrap>
                                    Action
                                </th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
                <div class="card-footer justify-center md:justify-between flex-col md:flex-row gap-3 text-gray-600 text-2sm font-medium">
                    <div class="flex items-center gap-2">
                        Show
                        <select class="select select-sm w-16" data-datatable-size="true"></select>
                        per page
                    </div>
                    <div class="flex items-center gap-4">
                        <span data-datatable-info="true"></span>
                        <div class="pagination" data-datatable-pagination="true"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="modalsection"></div>

@section PageScripts {
    <script src="~/js/Masters/uom.js?v=1.1.2"></script>
}