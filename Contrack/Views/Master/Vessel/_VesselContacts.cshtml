@model Contrack.VesselDTO
@using Contrack;
<div class="card h-full">
    <div class="card-header p-3 flex items-between">
        <h3 class="card-title">
            Contacts (@Model.Contacts.Count)
        </h3>
        @*@if (Model.Contacts.Count < 5 && PagePermission.GetPermissions().Vessel.edit)
        {*@
        <button type="button"
                onclick="OpenVesselContactModal('', '@Model.vassignment.vesselassignmentid.EncryptedValue')"
                class="btn btn-xs btn-sm btn-outline btn-light">
            <i class="ki-filled ki-plus"></i>
            Add Contact
        </button>

        @*}*@
    </div>
    <div class="card-body flex flex-col gap-5">
        @if (Model.Contacts.Count > 0)
        {
            <div class="flex flex-col gap-5">
                @for (int i = 0; i < Model.Contacts.Count; i++)
                {
                    <div class="flex items-center justify-between gap-2.5">
                        <div class="flex items-center gap-2.5">
                            <div class="">

                                <div class="size-10 rounded-full inline-flex items-center justify-center text-1xl font-semibold border border-primary-clarity bg-primary-light text-secondary">
                                    @Common.GetShortcode(Model.Contacts[i].fullname)
                                </div>
                            </div>
                            <div class="flex flex-col gap-0.5">
                                <a class="flex items-center gap-1.5 leading-none font-medium text-sm text-gray-900 hover:text-primary" href="javascript:void(0);">
                                    @Model.Contacts[i].fullname
                                    @if (Model.Contacts[i].isprimary)
                                    {
                                        <span class="mx-1 py-1 badge badge-outline badge-primary badge-sm">
                                            Primary
                                        </span>}
                                </a>
                                <span class="text-2sm text-gray-700">

                                    @Model.Contacts[i].position
                                    @if (!string.IsNullOrEmpty(Model.Contacts[i].email))
                                    {
                                        <span class="badge badge-dot size-1.5 bg-gray-500" style="margin-bottom: 1px; margin-left: 3px; margin-right: 3px; width: 5px; height: 5px; ">
                                        </span> @Model.Contacts[i].email}

                                </span>
                            </div>
                        </div>
                        @*@if (PagePermission.GetPermissions().Vessel.edit)
                        {*@
                            <div class="flex items-center gap-1.5">
                                @*@if (Model.Contacts[i].isprimary)
                                            {
                                    <span class="badge badge-outline badge-primary badge-sm">
                                        Primary
                                    </span>}*@
                                <div class="menu inline-flex" data-menu="true">
                                    <div class="menu-item menu-item-dropdown" data-menu-item-offset="0, 10px" data-menu-item-placement="bottom-end" data-menu-item-placement-rtl="bottom-start" data-menu-item-toggle="dropdown" data-menu-item-trigger="click|lg:click">
                                        <button class="menu-toggle btn btn-sm btn-icon btn-light btn-clear">
                                            <i class="ki-filled ki-dots-vertical">
                                            </i>
                                        </button>
                                        <div class="menu-dropdown menu-default w-full max-w-[175px]" data-menu-dismiss="true">
                                            <div class="menu-item">
                                                <a class="menu-link" href="javascript:void(0);" onclick="OpenVesselContactModal('@Model.Contacts[i].picid.EncryptedValue','@Model.vassignment.vesselassignmentid.EncryptedValue');">
                                                    <span class="menu-icon">
                                                        <i class="ki-filled ki-notepad-edit">
                                                        </i>
                                                    </span>
                                                    <span class="menu-title">
                                                        Edit
                                                    </span>
                                                </a>
                                            </div>
                                            <div class="menu-item">
                                                <a class="menu-link" href="javascript:void(0);" onclick="MakePrimary('@Model.Contacts[i].picid.EncryptedValue','@Model.vassignment.vesselassignmentid.EncryptedValue');">
                                                    <span class="menu-icon">
                                                        <i class="ki-filled ki-toggle-on-circle">
                                                        </i>
                                                    </span>
                                                    <span class="menu-title">
                                                        Make Primary
                                                    </span>
                                                </a>
                                            </div>
                                            <div class="menu-item">
                                                <a class="menu-link" href="javascript:void(0);" onclick="DeleteVesselContact('@Model.Contacts[i].picid.EncryptedValue','@Model.vassignment.vesselassignmentid.EncryptedValue');">
                                                    <span class="menu-icon">
                                                        <i class="ki-filled ki-trash">
                                                        </i>
                                                    </span>
                                                    <span class="menu-title">
                                                        Delete
                                                    </span>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        @*}*@
                    </div>}

            </div>}
        else
        {
            <span class="text-sm text-gray-500">   No contacts added</span>}
    </div>
</div>