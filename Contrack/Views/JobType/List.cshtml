@using Contrack
@{
    ViewBag.Title = "Job Types";
    ViewBag.MainManu = "More";
    ViewBag.SubManu = "JobTypes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="breadscrumb-holder">
    <div class="container-fluid flex items-center justify-between flex-wrap gap-5">
        <div class="flex flex-col justify-center items-start flex-wrap gap-1.5">
            <div class="flex items-center gap-1 text-sm font-normal">
                <span class="text-gray-700">Home</span>
                <span class="text-gray-400 text-sm">/</span>
                <span class="text-gray-700">Masters</span>
                <span class="text-gray-400 text-sm">/</span>
                <span class="text-gray-900">Job Types</span>
            </div>
            <h1 class="page-header">
                Job Types
            </h1>           
        </div>
        <div class="flex items-center flex-wrap gap-1.5 lg:gap-3.5">
            <div class="flex">
                <label class="input input-md">
                    <i class="ki-filled ki-magnifier"></i>
                    <input data-datatable-search="#TableJobTypeList" placeholder="Search" type="text" value="">
                </label>
            </div>
            <button class="btn btn-md btn-primary" onclick="OpenJobTypeModal('')">
                <i class="ki-filled ki-plus"></i>
                Create Job Type
            </button>
        </div>

    </div>
</div>

<div class="container-fluid">
    <div class="grid">
        <div class="card card-grid min-w-full">
            <div class="card-body">
                <div id="TableJobTypeList" class="custom-dt">
                    <div class="scrollable-x-auto">
                        <table class="table table-auto table-border align-middle text-gray-700 font-medium text-sm" data-datatable-table="true">
                            <thead>
                                <tr>
                                    <th class="min-w-[250px]" data-datatable-column="jobtypename">
                                        <span class="sort">
                                            <span class="sort-label">Job Type</span>
                                            <span class="sort-icon"></span>
                                        </span>
                                    </th>
                                    <th class="w-[170px] text-center" data-datatable-column="useasmaster">
                                        <span class="sort">
                                            <span class="sort-label">Use as Master</span>
                                            <span class="sort-icon"></span>
                                        </span>
                                    </th>
                                    <th class="w-[250px] text-center" data-datatable-column="lineitemcount">
                                        <span class="sort">
                                            <span class="sort-label">No of Line Items</span>
                                            <span class="sort-icon"></span>
                                        </span>
                                    </th>
                                    <th class="w-[150px] text-center" nowrap>
                                        Action
                                    </th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                    <div class="card-footer justify-center md:justify-between flex-col md:flex-row gap-3 text-gray-600 text-2sm font-medium">
                        <div class="flex items-center gap-2">
                            Show
                            <select class="select select-sm w-16" data-datatable-size="true"></select>
                            per page
                        </div>
                        <div class="flex items-center gap-4">
                            <span data-datatable-info="true"></span>
                            <div class="pagination" data-datatable-pagination="true"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="modalsection"></div>

@section PageScripts {
    <script src="~/js/Masters/job-types.js?v=1.1.2"></script>
}