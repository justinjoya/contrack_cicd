@model Contrack.UoMDTO

<div class="modal" data-modal="true" data-modal-backdrop-static="true" data-modal-autofocus="true" id="ModalUoM">
    <div class="modal-content modal-center-y max-w-[440px]">
        <div class="modal-header">
            <h3 class="modal-title">
                Add UOM
            </h3>
            <button class="btn btn-xs btn-icon btn-light" data-modal-dismiss="true">
                <i class="ki-outline ki-cross"></i>
            </button>
        </div>
        <div class="modal-body scrollable-y">
            <div class="model-req flex items-center grow rounded-xl border border-dashed gap-4 p-2 mb-3 border-primary bg-primary-light">
                <i class="ki-outline ki-information-1 text-3xl text-primary"></i>
                <div class="flex flex-col gap-0.5">
                    <p class="text text-2sm font-normal">
                        Fields marked with <span class="text-danger"> * </span> are mandatory.
                    </p>
                </div>
            </div>
            <form id="formUoM">
                <div class="grid lg:grid-cols-1 items-stretch gap-2">
                    <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                        <label class="form-label max-w-32 text-right">UOM <span class="text-danger ps-2">*</span></label>
                        <div class="flex flex-col w-full">
                            @Html.TextAreaFor(m => m.uomname, new
                            {
                                @rows = 4,
                                @class = "textarea",
                                @placeholder = "Enter UOM",
                                @datarequired = "yes",
                                @datarequired_message = "Please enter UOM"
                            })
                        </div>
                    </div>
                    <p class="italic text-muted text-xs text-right">
                        Add multiple UOMs using commas (e.g., PCs, Bundles, Containers).
                    </p>
                </div>
            </form>

        </div>
        <div class="modal-footer justify-end">
            <div class="flex gap-4">
                <button class="btn btn-light" data-modal-dismiss="true">Close</button>
                <button class="btn btn-primary" onclick="SaveUoM();">Save</button>
            </div>
        </div>
    </div>
</div>