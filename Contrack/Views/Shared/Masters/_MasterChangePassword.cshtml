@using Contrack;
@model Contrack.UserDTO
<div class="modal" data-modal="true" data-modal-backdrop-static="true" id="ModalChangePassword">
    <div class="modal-content modal-center-y max-w-[600px]">
        <div class="modal-header">
            <h3 class="modal-title">Change Password</h3>
            <button class="btn btn-xs btn-icon btn-light" data-modal-dismiss="true">
                <i class="ki-outline ki-cross"></i>
            </button>
        </div>
        <div class="modal-body scrollable-y">
            <div class="model-req flex items-center grow rounded-xl border border-dashed gap-4 p-2 mb-3 border-primary bg-primary-light">
                <i class="ki-outline ki-information-1 text-3xl text-primary"></i>
                <div class="flex flex-col gap-0.5">
                    <p class="text text-2sm font-normal">
                        Fields marked with <span class="text-danger">*</span> are mandatory.
                    </p>
                </div>
            </div>
            <form id="formChangePassword">
                <div>
                    <div class="flex flex-col gap-5">
                        <input type="hidden" name="UserID.EncryptedValue" value="@Model.UserID.EncryptedValue" />
                        <input type="hidden" name="Salt" value="@Model.Salt" />

                        <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                            <label class="form-label max-w-[170px]">User Name</label>
                            <div class="flex flex-col w-full items-baseline">
                                <div class="flex flex-col gap-0.5">
                                    <span class="leading-none font-medium text-sm text-gray-900">@Model.UserName</span>
                                </div>
                            </div>
                        </div>
                        <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                            <label class="form-label max-w-[170px]">Password <span class="text-danger ps-2">*</span></label>
                            <div class="flex flex-col w-full">
                                <input type="password" name="Password" class="input" placeholder="Enter Password" datarequired="yes" datarequired_message="Please enter Password" id="txt_password_change" />
                            </div>
                        </div>
                        <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                            <label class="form-label max-w-[170px]">Confirm Password <span class="text-danger ps-2">*</span></label>
                            <div class="flex flex-col w-full">
                                <input type="password" name="ConfirmPassword" class="input" placeholder="Confirm Password" datarequired="yes" datarequired_message="Confirm password should match with password" datatype="confirmpass" datamatchid="txt_password_change" />
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        <div class="modal-footer justify-end">
            <div class="flex gap-4">
                <button class="btn btn-light" data-modal-dismiss="true">Close</button>
                <button class="btn btn-primary" onclick="SavePassword();">Save Password</button>
            </div>
        </div>
    </div>
</div>