@model Contrack.JobTypeDetailDTO

<div class="modal" data-modal="true" data-modal-backdrop-static="true" data-modal-autofocus="true" id="ModalAddJobTypeDetail">
    <div class="modal-content modal-center-y max-w-[500px]">
        <div class="modal-header">
            <h3 class="modal-title">
                @(Model.jobtypedetailid.NumericValue == 0 ? "Add Line Item" : "Edit Line Item")
            </h3>
            <button class="btn btn-xs btn-icon btn-light" data-modal-dismiss="true">
                <i class="ki-outline ki-cross"></i>
            </button>
        </div>
        <div class="modal-body scrollable-y">
            <div class="model-req flex items-center grow rounded-xl border border-dashed gap-4 p-2 mb-3 border-primary bg-primary-light">
                <i class="ki-outline ki-information-1 text-3xl text-primary"></i>
                <div class="flex flex-col gap-0.5">
                    <p class="text text-2sm font-normal">
                        Fields marked with <span class="text-danger"> * </span> are mandatory.
                    </p>
                </div>
            </div>
            <form id="formJobTypeDetail">
                <input type="hidden" name="parentJobTypeIdEncrypted" value="@ViewBag.ParentJobTypeIdEncrypted" />

                @Html.HiddenFor(m => m.jobtypedetailid.EncryptedValue, new { Name = "jobtypedetail.jobtypedetailid.EncryptedValue" })
                @Html.HiddenFor(m => m.jobtypedetailid.NumericValue, new { Name = "jobtypedetail.jobtypedetailid.NumericValue" })

                <div class="grid lg:grid-cols-1 items-stretch gap-5">
                    <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                        <label class="form-label max-w-32 text-right">Job Type <span class="text-danger ps-2">*</span></label>
                        <div class="flex flex-col w-full">
                            <p class="form-control-static font-medium text-gray-600 pt-2">@Model.jobtypename</p>
                        </div>
                    </div>
                    <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                        <label class="form-label max-w-32 text-right">Description <span class="text-danger ps-2">*</span></label>
                        <div class="flex flex-col w-full">
                            @Html.TextAreaFor(m => m.description, new { @class = "textarea", @rows = 4, @placeholder = "Enter Description", @datarequired = "yes", Name = "jobtypedetail.description" })
                        </div>
                    </div>
                </div>
            </form>
        </div>
        <div class="modal-footer justify-end">
            <div class="flex gap-4">
                <button class="btn btn-light" data-modal-dismiss="true">Close</button>
                <button class="btn btn-primary" onclick="SaveJobTypeDetail();">Save</button>
            </div>
        </div>
    </div>
</div>