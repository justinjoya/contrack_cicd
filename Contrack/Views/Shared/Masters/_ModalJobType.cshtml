@model Contrack.JobType

<div class="modal" data-modal="true" data-modal-backdrop-static="true" data-modal-autofocus="true" id="ModalAddJobType">
    <div class="modal-content modal-center-y max-w-[600px]">
        <div class="modal-header">
            <h3 class="modal-title">
                @(Model.jobtype.jobtypeid.NumericValue == 0 ? "Add Job Type" : "Edit Job Type")
            </h3>
            <button class="btn btn-xs btn-icon btn-light" data-modal-dismiss="true">
                <i class="ki-outline ki-cross"></i>
            </button>
        </div>
        <div class="modal-body scrollable-y">
            <div class="model-req flex items-center grow rounded-xl border border-dashed gap-4 p-2 mb-3 border-primary bg-primary-light">
                <i class="ki-outline ki-information-1 text-3xl text-primary"></i>
                <div class="flex flex-col gap-0.5">
                    <p class="text text-2sm font-normal">
                        Fields marked with <span class="text-danger"> * </span> are mandatory.
                    </p>
                </div>
            </div>
            <form id="formJobType">
                @Html.HiddenFor(m => m.jobtype.jobtypeid.NumericValue)
                @Html.HiddenFor(m => m.jobtype.jobtypeid.EncryptedValue)

                <div class="grid lg:grid-cols-1 items-stretch gap-5">
                    <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                        <label class="form-label min-w-32 text-right">Job Type <span class="text-danger ps-2">*</span></label>
                        <div class="flex flex-col w-full">
                            @Html.TextBoxFor(m => m.jobtype.jobtypename, new { @class = "input", @placeholder = "Enter Job Type Name", @datarequired = "yes", @datarequired_message = "Please enter Job Name" })
                        </div>
                    </div>
                    <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                        <label class="form-label min-w-32 text-right">Short Code</label>
                        <div class="flex flex-col w-full">
                            @Html.TextBoxFor(m => m.jobtype.jobshortcode, new { @class = "input", @placeholder = "Enter Short Code" })
                        </div>
                    </div>
                    <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                        <label class="form-label min-w-32 text-right">Use as Master</label>
                        <div class="flex flex-col w-full">
                            <label class="switch switch-sm">
                                @Html.CheckBoxFor(m => m.jobtype.useasmaster)
                                <span class="switch-button"></span>
                            </label>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        <div class="modal-footer justify-end">
            <div class="flex gap-4">
                <button class="btn btn-light" data-modal-dismiss="true">Close</button>
                <button class="btn btn-primary" onclick="SaveJobType();">Save</button>
            </div>
        </div>
    </div>
</div>