@using Contrack;
@model Contrack.UserDTO
<div class="modal" data-modal="true" data-modal-backdrop-static="true" data-modal-autofocus="true" id="ModalAddUser">
    <div class="modal-content modal-center-y max-w-[600px] max-h-[95%]">
        <div class="modal-header">
            <h3 class="modal-title">
                @if (string.IsNullOrEmpty(Model.UserID.EncryptedValue))
                {
                    @Html.Raw("Add User")
                }
                else
                {
                    @Html.Raw("Edit User (" + Model.UserName + ")")
                }
            </h3>
            <button class="btn btn-xs btn-icon btn-light" data-modal-dismiss="true">
                <i class="ki-outline ki-cross">
                </i>
            </button>
        </div>
        <div class="modal-body scrollable-y">
            <div class="model-req flex items-center grow rounded-xl border border-dashed gap-4 p-2 mb-3 border-primary bg-primary-light">
                <i class="ki-outline ki-information-1 text-3xl text-primary">
                </i>
                <div class="flex flex-col gap-0.5">
                    <p class="text text-2sm font-normal">
                        Fields marked with <span class="text-danger"> * </span> are mandatory.
                    </p>
                </div>
            </div>
            <form id="formUser">
                <div>
                    <div class="flex flex-col gap-5">
                        <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                            <label class="form-label max-w-[170px] text-right">
                                User Name <span class="text-danger ps-2">*</span>
                            </label>
                            @Html.HiddenFor(m => m.UserID.EncryptedValue)
                            <div class="flex flex-col w-full">
                                <div class="flex flex-col gap-3">

                                    @if (string.IsNullOrEmpty(Model.UserID.EncryptedValue))
                                    {
                                        @Html.TextBoxFor(m => m.UserName, new { @class = "input", @placeholder = "Enter User Name", @datarequired = "yes", @datarequired_message = "Please enter User Name", @id = "txt_username" })
                                        <div>
                                            <button type="button" class="pull-right btn btn-xs btn-sm btn-light" onclick="Checkavailability();">
                                                <i class="ki-filled ki-magnifier">
                                                </i>
                                                Check Availability
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        @Html.TextBoxFor(m => m.UserName, new { @class = "input", @placeholder = "Enter User Name", @datarequired = "yes", @datarequired_message = "Please enter User Name", @id = "txt_username", @disabled = true })
                                    }
                                </div>
                            </div>

                        </div>

                        <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                            <label class="form-label max-w-[170px]">
                                Create for <span class="text-danger ps-2">*</span>
                            </label>
                            <div class="flex flex-col w-full items-baseline">
                                @{
                                    string type = "";
                                    var list = (List<System.Web.UI.WebControls.ListItem>)ViewBag.UserTypeDropdown;
                                    list = list.Where(x => x.Value != "").ToList();

                                    var selected = list.Where(x => x.Value == Model.Type.EncryptedValue).FirstOrDefault();
                                    if (selected != null)
                                    {
                                        type = selected.Text;
                                    }

                                    if (string.IsNullOrEmpty(Model.Type.EncryptedValue))
                                    {
                                        <div class="grid grid-cols-3 lg:grid-cols-3 xl:grid-cols-3 gap-5">
                                            @{
                                                for (int i = 0; i < list.Count; i++)
                                                {
                                                    <label for="radio@(i)" class="form-label flex items-center gap-2.5 text-nowrap" onclick="ShowHideEntity('@list[i].Value');">
                                                        <input id="radio@(i)" class="radio" name="Type.EncryptedValue" type="radio" value="@list[i].Value">
                                                        @list[i].Text
                                                    </label>
                                                }
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        @Html.HiddenFor(m => m.Type.EncryptedValue)
                                        <div class="flex items-center gap-4">
                                            <div class="leading-none w-5 shrink-0">
                                                @if (Common.Decrypt(Model.Type.EncryptedValue) == 1)
                                                {
                                                    <i class="ki-filled ki-people text-primary text-2xl"></i>
                                                }
                                                else if (Common.Decrypt(Model.Type.EncryptedValue) == 2)
                                                {
                                                    <i class="ki-filled ki-users text-warning text-2xl"></i>
                                                }
                                                else
                                                {
                                                    <i class="ki-filled ki-users text-gray-500 text-2xl"></i>
                                                }
                                            </div>
                                            <div class="flex flex-col gap-0.5">
                                                <span class="leading-none font-medium text-sm text-gray-900">@type</span>
                                                <span class="text-2sm text-gray-700 font-normal">@Model.EntityName</span>
                                            </div>
                                        </div>
                                    }

                                    if (Model.Type.EncryptedValue != Common.Encrypt(Common.UserType) || string.IsNullOrEmpty(Model.Type.EncryptedValue))
                                    {
                                        <div class="flex flex-col w-full pt-5 entity" style="@(Common.Decrypt(Model.Type.EncryptedValue)==2?"":"display:none;") " id="Entity_@Common.Encrypt(2)">
                                            @Html.ListBoxFor(m => m.EntityIDEncryptedList, new SelectList(@ViewBag.AgenciesDropdown, "Value", "Text", "") { }, new { @id = "ddlAgencies", @placeholder = "Select agencies", @class = "form-control select2", @multiple = true })
                                        </div>

                                        // client
                                        <div class="flex flex-col w-full pt-5 entity" style="display:none;" id="Entity_@Common.Encrypt(3)">
                                            <div class="holderdropdown">
                                                <div class="search-wrapper customerselection">
                                                    @Html.ListBoxFor(m => m.EntityIDEncryptedList,
                                                    new SelectList(ViewBag.ClientDropdown, "Value", "Text", ""),
                                                    new
                                                    {
                                                        @class = "form-control select2 customerselect2",
                                                        @id = "ddlCustomer",
                                                        @style = "width:100%;",
                                                        @datarequired = "yes",
                                                        @datarequired_message = "Please select Customer",
                                                        @data_append_parent = "no",
                                                        @dataid = "",
                                                        @dataname = ""
                                                    })
                                                </div>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        for (int i = 0; i < Model.EntityIDEncryptedList.Count; i++)
                                        {
                                            <input type="hidden" name="EntityIDEncryptedList[@i]" value="@Model.EntityIDEncryptedList[i]" />
                                        }
                                    }

                                }
                            </div>
                        </div>

                        <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                            <label class="form-label max-w-[170px]">
                                Name <span class="text-danger ps-2">*</span>
                            </label>
                            <div class="flex flex-col w-full">
                                @if (string.IsNullOrEmpty(Model.UserID.EncryptedValue))
                                {
                                    @Html.TextBoxFor(m => m.Name, new { @class = "input", @placeholder = "Enter Name", @datarequired = "yes", @datarequired_message = "Please enter Name", @disabled = true })
                                }
                                else
                                {
                                    @Html.TextBoxFor(m => m.Name, new { @class = "input", @placeholder = "Enter Name", @datarequired = "yes", @datarequired_message = "Please enter Name" })
                                }
                            </div>
                        </div>
                        <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                            <label class="form-label max-w-[170px]">
                                Email <span class="text-danger ps-2">*</span>
                            </label>
                            <div class="flex flex-col w-full">
                                @if (string.IsNullOrEmpty(Model.UserID.EncryptedValue))
                                {
                                    @Html.TextBoxFor(m => m.Email, new { @class = "input", @placeholder = "Enter Email", @datarequired = "yes", @datarequired_message = "Please enter Email", @disabled = true })
                                }
                                else
                                {
                                    @Html.TextBoxFor(m => m.Email, new { @class = "input", @placeholder = "Enter Email", @datarequired = "yes", @datarequired_message = "Please enter Email" })
                                }
                            </div>
                        </div>

                        <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                            <label class="form-label max-w-[170px]">
                                Phone
                            </label>
                            <div class="flex flex-col w-full">
                                @if (string.IsNullOrEmpty(Model.UserID.EncryptedValue))
                                {
                                    @Html.TextBoxFor(m => m.Phone, new { @class = "input", @placeholder = "Enter Phone", @datarequired = "no", @datarequired_message = "Please enter Phone", @disabled = true })
                                }
                                else
                                {
                                    @Html.TextBoxFor(m => m.Phone, new { @class = "input", @placeholder = "Enter Phone", @datarequired = "no", @datarequired_message = "Please enter Phone" })
                                }
                            </div>
                        </div>
                        @if (string.IsNullOrEmpty(Model.UserID.EncryptedValue))
                        {
                            <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                                <label class="form-label max-w-[170px]">
                                    Password <span class="text-danger ps-2">*</span>
                                </label>
                                <div class="flex flex-col w-full">
                                    @Html.PasswordFor(m => m.Password, new { @class = "input", @placeholder = "Enter Password", @datarequired = Model.UserID.NumericValue == 0 ? "yes" : "no", @datarequired_message = "Please enter Password", @id = "txt_password", @disabled = true })
                                </div>
                            </div>
                            <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                                <label class="form-label max-w-[170px]">
                                    Confirm Password <span class="text-danger ps-2">*</span>
                                </label>
                                <div class="flex flex-col w-full">
                                    @Html.Password("ConfirmPassword", "", new { @class = "input", @placeholder = "Enter Confirm Password", @datarequired = Model.UserID.NumericValue == 0 ? "yes" : "no", @datarequired_message = "Confirm password should match with password", @datatype = "confirmpass", @datamatchid = "txt_password", @disabled = true })
                                </div>
                            </div>
                        }
                        <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                            <label class="form-label max-w-[170px]">
                                Role <span class="text-danger ps-2">*</span>
                            </label>
                            <div class="flex flex-col w-full">
                                @if (string.IsNullOrEmpty(Model.UserID.EncryptedValue))
                                {
                                    @Html.DropDownListFor(m => m.RoleID.EncryptedValue, new SelectList(@ViewBag.RolesDropdown, "Value", "Text", "") { }, new { @id = "ddlRole", @placeholder = "Select Role", @class = "form-control select2", @disabled = true })
                                }
                                else
                                {
                                    @Html.DropDownListFor(m => m.RoleID.EncryptedValue, new SelectList(@ViewBag.RolesDropdown, "Value", "Text", "") { }, new { @id = "ddlRole", @placeholder = "Select Role", @class = "form-control select2" })
                                }

                            </div>
                        </div>
                    </div>


                </div>
            </form>
        </div>
        <div class="modal-footer justify-end">
            <div class="flex gap-4">
                <button class="btn btn-light" data-modal-dismiss="true">
                    Close
                </button>

                <button class="btn btn-primary" onclick="SaveUser();" id="btn_save_user" @(Model.UserID.NumericValue == 0 ? "disabled" : "")>
                    Save User
                </button>

            </div>
        </div>
    </div>
</div>