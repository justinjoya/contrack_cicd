@using Contrack;
@model Contrack.KeyValuePair
<div class="modal hidden" data-modal="true" data-modal-backdrop-static="true" data-modal-autofocus="true" id="ModalCustomKeyValue">
    <div class="modal-content modal-center max-w-[440px]">
        <div class="modal-header">
            <h3 class="modal-title">
                Add Custom Attribute
            </h3>
            <button class="btn btn-xs btn-icon btn-light" data-modal-dismiss="true">
                <i class="ki-outline ki-cross">
                </i>
            </button>
        </div>
        <div class="modal-body">
            @*<div class="model-req flex items-center grow rounded-xl border border-dashed gap-4 p-2 mb-3 border-primary bg-primary-light">
                    <i class="ki-outline ki-information-1 text-3xl text-primary">
                    </i>
                    <div class="flex flex-col gap-0.5">
                        <p class="text text-2sm font-normal">
                            Fields marked with <span class="text-danger"> * </span> are mandatory.
                        </p>
                    </div>
                </div>*@
            <form id="formCustomKeyValue">
                <div>
                    <div class="flex flex-col gap-5">
                        @Html.HiddenFor(m => m.UUID)
                        <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                            <div class="flex flex-col w-full gap-3">
                                @Html.TextBoxFor(m => m.KeyName, new { @class = "input CustomePlaceholderKey", @placeholder = "Enter Field Name", @datarequired = "yes", @datarequired_message = "Please enter Field Name", @id = "txt_keyname" })
                                @Html.TextAreaFor(m => m.KeyValue, new { @class = "textarea", @rows = 4, @placeholder = "Enter Field Value", @datarequired = "yes", @datarequired_message = "Please enter Field value", @id = "txt_keyvalue" })
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
        <div class="modal-footer justify-end">
            <div class="flex gap-4">
                <button class="btn btn-light" data-modal-dismiss="true">
                    Close
                </button>
                @*@if (PagePermission.GetPermissions().Agency.edit)
                    {
                        <button class="btn btn-primary" onclick="SaveCustomAttribute();">
                            Save
                        </button>
                    }*@
                <button class="btn btn-primary" onclick="SaveCustomAttribute();">
                    Save
                </button>
            </div>
        </div>
    </div>
</div>