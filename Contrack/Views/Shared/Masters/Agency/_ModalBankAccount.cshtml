@using Contrack;
@model Contrack.CustomBankInfo
<div class="modal hidden" data-modal="true" data-modal-backdrop-static="true" data-modal-autofocus="true" id="ModalBankAccount">
    <div class="modal-content max-w-[60%]">
        <div class="modal-header">
            <h3 class="modal-title">
                Add Bank Account
            </h3>
            <button class="btn btn-xs btn-icon btn-light" data-modal-dismiss="true">
                <i class="ki-outline ki-cross">
                </i>
            </button>
        </div>
        <div class="modal-body scrollable-y">
            @*<div class="model-req flex items-center grow rounded-xl border border-dashed gap-4 p-2 mb-3 border-primary bg-primary-light">
                    <i class="ki-outline ki-information-1 text-3xl text-primary">
                    </i>
                    <div class="flex flex-col gap-0.5">
                        <p class="text text-2sm font-normal">
                            Fields marked with <span class="text-danger"> * </span> are mandatory.
                        </p>
                    </div>
                </div>*@
            <form id="formBankAccount">
                <div>
                    <div class="flex flex-col gap-5">
                        @Html.HiddenFor(m => m.BankAccountUUID)
                        @*@Html.HiddenFor(m => m.Salt)*@

                        <div class="flex flex-row items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                            <label class="form-label max-w-[170px]">
                                Alias Name
                            </label>
                            <div class="flex flex-col w-full ">
                                <div class="flex">
                                    @Html.TextBoxFor(m => m.AliasName, new { @class = "input", @placeholder = "Enter Alias Name", @datarequired = "yes", @datarequired_message = "Please enter Alias Name", @id = "txt_AliasName", @style = "width:100%;" })
                                    @*<div style="width:50%"></div>*@
                                </div>
                            </div>
                            <div style="width:50px;"></div>
                            <label class="form-label max-w-[170px]">
                                Currency
                            </label>
                            <div class="flex flex-col w-full">
                                <div class="flex">
                                    @Html.DropDownListFor(m => m.Currency, new SelectList(@ViewBag.CurrencyDropdown, "Value", "Text", Model.Currency) { }, new { @class = "input select2", @placeholder = "Select Currency", @datarequired = "yes", @datarequired_message = "Please select Currency", @id = "txt_Currency", @style = "width:100%;" })
                                    @*<div style="width:50%"></div>*@
                                </div>
                            </div>

                        </div>
                        <hr />
                        @*<div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                                <label class="form-label max-w-[170px]">
                                    Currency
                                </label>
                                <div class="flex flex-col w-full">
                                    <div class="flex">
                                        @Html.DropDownListFor(m => m.Currency, new SelectList(@ViewBag.CurrencyDropdown, "Value", "Text", Model.Currency) { }, new { @class = "input select2", @placeholder = "Select Currency", @datarequired = "yes", @datarequired_message = "Please select Currency", @id = "txt_Currency", @style = "max-width:500px;width:100%;" })
                                        <div style="width:50%"></div>
                                    </div>
                                </div>
                                <div></div>
                            </div>*@
                        <div class="grid grid-cols-2 lg:grid-cols-2 gap-5 lg:gap-5">
                            @for (int i = 0; i < Model.BankAttributes.Count; i++)
                            {
                                var fieldname = "Field Value";
                                if (!string.IsNullOrEmpty(Model.BankAttributes[i].KeyName))
                                {
                                    fieldname = Model.BankAttributes[i].KeyName;
                                }
                                <div class="flex flex-row gap-3" style="@(string.IsNullOrEmpty(Model.BankAttributes[i].KeyName)?"display:none1;":"")">
                                    @Html.TextBoxFor(m => m.BankAttributes[i].KeyName, new { @class = "max-w-[170px] input CustomePlaceholderKey", @placeholder = "Enter Field Name", @datarequired = "no", @datarequired_message = "Please enter Field Name", @id = "txt_keyname" })
                                    @Html.TextBoxFor(m => m.BankAttributes[i].KeyValue, new { @class = "textarea", @rows = 3, @placeholder = "Enter " + fieldname, @datarequired = "no", @datarequired_message = "Please enter Field value", @id = "txt_keyvalue" })
                                    <a class="btn btn-sm btn-icon btn-clear btn-danger" href="javascript:void(0)" onclick="ClearBankAccount(this);"><i class="ki-filled ki-filled ki-trash"></i></a>
                                </div>

                            }

                        </div>
                    </div>
                </div>
            </form>
        </div>
        <div class="modal-footer justify-end">
            <div class="flex gap-4">
                <button class="btn btn-light" data-modal-dismiss="true">
                    Close
                </button>
                @*@if (PagePermission.GetPermissions().Agency.edit)
                    {
                        <button class="btn btn-primary" onclick="SaveBankAccount();">
                            Save
                        </button>
                    }*@
                <button class="btn btn-primary" onclick="SaveBankAccount();">
                    Save
                </button>
            </div>
        </div>
    </div>
</div>