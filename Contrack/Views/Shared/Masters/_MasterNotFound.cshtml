@model Contrack.NotFound
<div class="flex flex-col items-center justify-center h-[95%]">
    <div class="mb-10">
        <img alt="image" class="dark:hidden max-h-[160px]" src="~/assets/content/19.svg">
        <img alt="image" class="light:hidden max-h-[160px]" src="~/assets/content/19-dark.svg">
    </div>
    <span class="badge badge-primary badge-outline mb-3">
        404 Error
    </span>
    <h3 class="text-2.5xl font-semibold text-gray-900 text-center mb-2">
        @Model.Message
        @*We have lost this page*@
    </h3>
    @if (!string.IsNullOrEmpty(Model.ReturnButton))
    {
        <div class="text-md text-center text-gray-700 mb-10">
            The requested page is missing. Check the URL or
            <a class="text-primary font-medium hover:text-primary-active" href="@Model.ReturnURL">
                Return to @Model.ReturnButton
            </a>
            .
        </div>
    }
    @*<div class="relative">
            <input class="input ps-8 max-w-64" placeholder="Search Metronic" type="text" value="">
            <a href="@Model.ReturnURL" class="btn btn-clear btn-icon text-gray-500 btn-sm absolute start-0 top-2/4 -translate-y-2/4 ms-1">
                <i class="ki-filled ki-magnifier">
                </i>
            </a>
        </div>*@
</div>