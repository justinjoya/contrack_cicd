@model Contrack.Tracking
@using Contrack;
<style>
    .SaveRecord {
        display: none;
    }
</style>
@{
    var notavailablelist = Model.AvailList.Where(x => !x.is_available).ToList();
}
<div class="modal" data-modal="true" data-modal-backdrop-static="true" data-modal-autofocus="true" id="ModalRecordMove">
    <div class="modal-content modal-center-y max-w-[60%] max-h-[95%]">
        <div class="modal-header">
            <h3 class="modal-title">
                @if (@Common.Decrypt(Model.Trackingmodel.TrackingId.EncryptedValue) > 0)
                {
                    @Html.Raw("Edit Record Move")
                }
                else
                {
                    @Html.Raw("Add Record Move")
                }
            </h3>
            <button class="btn btn-xs btn-icon btn-light" data-modal-dismiss="true">
                <i class="ki-outline ki-cross">
                </i>
            </button>
        </div>
        <div class="modal-body scrollable-y">
            @*<div class="model-req flex items-center grow rounded-xl border border-dashed gap-4 p-2 mb-3 border-primary bg-primary-light">
                    <i class="ki-outline ki-information-1 text-3xl text-primary">
                    </i>
                    <div class="flex flex-col gap-0.5">
                        <p class="text text-2sm font-normal">
                            Fields marked with <span class="text-danger"> * </span> are mandatory.
                        </p>
                    </div>
                </div>*@
            @Html.Partial("~/Views/Shared/Tracking/_RecordMoveSection.cshtml")
        </div>
        <div class="modal-footer justify-between">
            <span class="text-xs text-gray-600 italic">
                <span class="text-danger">*</span> Required fields for template creation
            </span>
            <div class="flex gap-4">
                <button class="btn btn-light" data-modal-dismiss="true">
                    Close
                </button>
                @if (notavailablelist.Count == 0)
                {
                    <button class="btn btn-primary" onclick="SaveRecordMove();">
                        Save Move
                    </button>
                }
            </div>
        </div>
    </div>
</div>