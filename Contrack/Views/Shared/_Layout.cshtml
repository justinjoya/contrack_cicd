    <script src="~/assets/js/core.bundle.js">
    </script>
    <script src="~/assets/vendors/apexcharts/apexcharts.min.js">
    </script>
    <script src="~/assets/libs/sweetalert2/sweetalert2.min.js"></script>
    <script src="~/assets/js/toastify-js.js" type="text/javascript"></script>
    <script src="~/assets/js/blockui.js"></script>
    <script src="~/assets/js/select2.min.js"></script>
    <script src="~/assets/js/cleave.min.js"></script>
    <script src="~/assets/flatpickr/flatpickr.min.js"></script>

