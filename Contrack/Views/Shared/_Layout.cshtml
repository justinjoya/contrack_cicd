                                @*<div class="profile-name">
                                    <div class="avatar">@Common.GetShortcode(Common.LoginName)</div>
                                    <div class="name">@Common.LoginName</div>
                                    <img src="~/assets/icons/arrowdown.svg" />
                                </div>*@
