                                                        Log out
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                @*<div class="menu-dropdown floater menu-default py-2.5 w-full max-w-[220px]">
            <div class="menu-item @(ViewBag.SubMenu=="PIntent"?"active":"")">
                <a class="menu-link" href="@Url.Action("List","Agency")" tabindex="0">
                    <span class="menu-icon">
                        <i class="ki-filled ki-purchase"></i>
                    </span>
                    <span >
                        Companies
                    </span>
                </a>
            </div>
            <div class="menu-item @(ViewBag.SubMenu=="POList"?"active":"")">
                <a class="menu-link" href="@Url.Action("List","Client")" tabindex="0">
                    <span class="menu-icon">
                        <i class="ki-filled ki-book"></i>

                    </span>
                    <span class="menu-title grow-0">
                        Clients
                    </span>
                </a>
            </div>
        </div>*@
                            </div>
