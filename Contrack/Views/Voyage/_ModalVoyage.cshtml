@model Contrack.VoyageExtention
@using Contrack;
@{
    var formMode = ViewBag.FormMode?.ToString()?.ToLower();
    bool isEdit = Model.VoyageExtendedDTO.VoyageId.NumericValue > 0;
    bool isViewOnly = isEdit && formMode != "editvoyage";
    bool isEditVoyage = formMode == "editvoyage";
    bool isAddPort = formMode == "addport";
}

<input type="hidden" id="IsEditMode" value="@isEdit.ToString().ToLower()" />
<input type="hidden" id="FormMode" value="@ViewBag.FormMode" />
<div class="modal" data-modal="true" data-modal-backdrop-static="true" data-modal-autofocus="true" id="ModalAddVoyage">
    <div class="modal-content modal-center-y max-w-[600px] max-h-[95%]">
        <div class="modal-header">
            <h3 class="modal-title">
                @{
                    var voyageId = Model.VoyageExtendedDTO.VoyageId.NumericValue;

                    if (formMode == "addport" || voyageId == 0)
                    {
                        @Html.Raw("Add Voyage")
                    }
                    else
                    {
                        @Html.Raw("Edit Voyage")
                    }
                }
            </h3>

            <button class="btn btn-xs btn-icon btn-light" data-modal-dismiss="true">
                <i class="ki-outline ki-cross"></i>
            </button>
        </div>

        <div class="modal-body scrollable-y">
            <div class="model-req flex items-center grow rounded-xl border border-dashed gap-4 p-2 mb-3 border-primary bg-primary-light">
                <i class="ki-outline ki-information-1 text-3xl text-primary"></i>
                <div class="flex flex-col gap-0.5">
                    <p class="text text-2sm font-normal">
                        Fields marked with <span class="text-danger"> * </span> are mandatory.
                    </p>
                </div>
            </div>
            <form id="formVoyage">
                @Html.HiddenFor(m => m.VoyageExtendedDTO.VoyageDetails.VoyageDetailId.EncryptedValue)
                @Html.HiddenFor(m => m.VoyageExtendedDTO.VoyageId.EncryptedValue, new { @id = "VoyageId_EncryptedValue" })
                @Html.HiddenFor(m => m.VoyageExtendedDTO.VoyageUuid)
                <div class="grid lg:grid-cols-1 gap-5">
                    <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                        <label class="form-label max-w-32">
                            Voyage <span class="text-danger ps-2">*</span>
                        </label>
                        <div class="flex flex-col fixed-width">
                            @if (isViewOnly || isAddPort)
                            {
                                <label class="form-label">
                                    @Model.VoyageExtendedDTO.VoyageNumber
                                </label>
                            }
                            else if (isEditVoyage)
                            {
                                @Html.TextBoxFor(m => m.VoyageExtendedDTO.VoyageNumber, new { @class = "input", })
                            }
                            else
                            {
                                <div class="flex flex-col">
                                    @Html.DropDownListFor(m => m.VoyageExtendedDTO.VoyageId.EncryptedValue, new SelectList(ViewBag.VoyageDropdown, "Value", "Text", Model.VoyageExtendedDTO.VoyageId.EncryptedValue), "Select Voyage", new { @class = "select2", @id = "ddlVoyage", @datarequired = "yes", @datarequired_message = "Please select voyage", @data_append_parent = "yes" })
                                </div>
                            }
                            @Html.HiddenFor(m => m.VoyageExtendedDTO.VoyageId.EncryptedValue)
                            @Html.HiddenFor(m => m.VoyageExtendedDTO.VoyageNumber, new { @id = "VoyageExtendedDTO_VoyageNumber" })

                        </div>
                    </div>
                    <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                        <label class="form-label max-w-32">
                            Vessel Name <span class="text-danger ps-2">*</span>
                        </label>
                        <div class="flex flex-col w-full">
                            @if (isViewOnly || isAddPort)
                            {
                                <label class="form-label">
                                    @Model.VoyageExtendedDTO.Vesselname
                                </label>
                                @Html.HiddenFor(m => m.VoyageExtendedDTO.VesseDetailId.EncryptedValue)
                            }
                            else
                            {
                                <div class="flex flex-col">
                                    @Html.DropDownListFor(m => m.VoyageExtendedDTO.VesseDetailId.EncryptedValue, new SelectList(ViewBag.VesselDropdown, "Value", "Text", Model.VoyageExtendedDTO.VesseDetailId.EncryptedValue), "Select Vessel", new { @class = "select2", @id = "ddlVesselDetailID", @datarequired = "yes", @datarequired_message = "Please select Vessel", @data_append_parent = "yes", @datatext = Model.VoyageExtendedDTO.Vesselname, @datavalue = Model.VoyageExtendedDTO.VesseDetailId.EncryptedValue })
                                </div>
                            }
                        </div>
                    </div>
                    <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                        <label class="form-label max-w-32 text-right">
                            Comments
                        </label>
                        <div class="flex flex-col w-full">
                            @if (isViewOnly)
                            {
                                <label class="form-label">
                                    @Model.VoyageExtendedDTO.Description
                                </label>
                                @Html.HiddenFor(m => m.VoyageExtendedDTO.Description)
                            }
                            else
                            {
                                @Html.TextAreaFor(m => m.VoyageExtendedDTO.Description, new { @class = "textarea", id = "txtComments", @placeholder = "Enter comment" })
                            }
                        </div>
                    </div>

                    @if (!isEditVoyage)
                    {
                        <div class="flex flex-col1 items-baseline gap-1.5">
                            <label class="form-label max-w-32">Port <span class="text-danger ps-2">*</span></label>
                            <div class="flex flex-col w-full portmultiline">
                                <div class="flex flex-col">
                                    @Html.DropDownListFor(m => m.VoyageExtendedDTO.VoyageDetails.PortId.EncryptedValue,
                                     new SelectList(ViewBag.PortDropdown, "Value", "Text", ""),
                                     "Select Port",
                                     new
                                     {
                                         @class = "select2",
                                         @id = "ddlPOL",
                                         @datarequired = "yes",
                                         @datarequired_message = "Please select Port",
                                         @data_placeholder_main = "Port",
                                         @data_placeholder_sub = "Select Port",
                                         @data_append_parent = "yes",
                                         @dataportid = Model.VoyageExtendedDTO.VoyageDetails.PortId.EncryptedValue,
                                         @dataportname = Model.VoyageExtendedDTO.VoyageDetails.portname,
                                         @datacountryname = Model.VoyageExtendedDTO.VoyageDetails.CountryName,
                                         @dataportcode = Model.VoyageExtendedDTO.VoyageDetails.portcode,
                                         @dataflag = Contrack.Common.FlagFolder + Model.VoyageExtendedDTO.VoyageDetails.CountryFlag
                                     })
                                </div>
                            </div>
                        </div>
                        <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                            <label class="form-label max-w-32 text-right">
                                Terminal <span class="text-danger ps-2">*</span>
                            </label>
                            <div class="flex flex-col w-full">
                                @Html.TextBoxFor(m => m.VoyageExtendedDTO.VoyageDetails.Terminal, new { @class = "input", @placeholder = "Enter Terminal", @datarequired = "yes", @datarequired_message = "Please enter Terminal" })
                            </div>
                        </div>



                        <div class="flex flex-col1 items-baseline gap-1.5">
                            <label class="form-label max-w-32">ETA <span class="text-danger ps-2">*</span></label>
                            <div class="flex flex-col w-full">
                                <div class="input-group w-full">
                                    @Html.TextBoxFor(m => m.VoyageExtendedDTO.VoyageDetails.ETA.DBFormattedText, new { @data_trigger = "btnTarget", @data_min_date_field = "ETD_Date", @class = "datetimepicker-here input", @placeholder = "dd/mm/yyyy hh:mm", @datarequired = "yes", @datarequired_message = "Please Enter ETA", @id = "txt_DateTimePI", @data_provider = "flatpickr1", @data_clear = "btnClearDate", @readonly = true, @datavalidate = "yes", @data_append_parent = "yes", })
                                    <button type="button" id="btnTarget" class="btn btn-icon btn-outline btn-icon-lg btn-light">
                                        <i class="ki-filled ki-calendar-2"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col1 items-baseline gap-1.5">
                            <label class="form-label max-w-32">ETD <span class="text-danger ps-2">*</span></label>
                            <div class="flex flex-col w-full">
                                <div class="input-group w-full">
                                    @Html.TextBoxFor(m => m.VoyageExtendedDTO.VoyageDetails.ETD.DBFormattedText, new { @data_trigger = "btnTarget1", @class = "datetimepicker-here input", @placeholder = "dd/mm/yyyy hh:mm", @datarequired = "yes", @datarequired_message = "Please Enter ETD", @id = "ETD_Date", @data_provider = "flatpickr1", @datavalidate = "yes", @data_append_parent = "yes", })
                                    <button type="button" id="btnTarget1" class="btn btn-icon btn-outline btn-icon-lg btn-light">
                                        <i class="ki-filled ki-calendar-2"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col1 items-baseline gap-1.5">
                            <label class="form-label max-w-32">Cutoff Deadline <span class="text-danger ps-2">*</span></label>
                            <div class="flex flex-col w-full">
                                <div class="input-group w-full">
                                    @Html.TextBoxFor(m => m.VoyageExtendedDTO.VoyageDetails.CutoffDeadline.DBFormattedText, new { @data_trigger = "btnTarget2",@class = "datetimepicker-here input", @placeholder = "dd/mm/yyyy hh:mm", @datarequired = "yes", @datarequired_message = "Please enter Cutoff Deadline", @id = "Cutoff_Date", @data_provider = "flatpickr1", @datavalidate = "yes", @data_append_parent = "yes", })
                                    <button type="button" id="btnTarget2" class="btn btn-icon btn-outline btn-icon-lg btn-light">
                                        <i class="ki-filled ki-calendar-2"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col1 items-baseline gap-1.5">
                            <label class="form-label max-w-32">Departure Captain</label>
                            @Html.TextBoxFor(m => m.VoyageExtendedDTO.VoyageDetails.DepartureCaptain, new { @class = "input", @placeholder = "Enter Departure Captain" })
                        </div>

                        <div class="flex flex-col1 items-baseline gap-1.5">
                            <label class="form-label max-w-32">Arrival Captain</label>
                            @Html.TextBoxFor(m => m.VoyageExtendedDTO.VoyageDetails.ArrivalCaptain, new { @class = "input", @placeholder = "Enter Arrival Captain" })
                        </div>
                    }
                </div>
            </form>
        </div>

        <div class="modal-footer justify-end">
            <div class="flex gap-4">
                <button class="btn btn-light" data-modal-dismiss="true">Close</button>
                <button type="button" class="btn btn-primary" onclick="SaveVoyage()">Save Voyage</button>
            </div>
        </div>
    </div>
</div>
