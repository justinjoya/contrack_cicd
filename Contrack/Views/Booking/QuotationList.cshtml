@model Contrack.QuotationListFilter
@using Contrack

@{
    ViewBag.Title = "Quotation List";
    ViewBag.MainManu = "Booking";
    ViewBag.SubManu = "Quotation List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="breadscrumb-holder">
    <div class="container-fluid flex items-center justify-between flex-wrap gap-5">

        <div class="flex flex-col justify-center items-start flex-wrap gap-1 lg:gap-2">

            <h1 class="page-header">Quotation List</h1>
            <div class="flex items-center gap-1 text-sm font-normal">
                <span class="text-gray-700">Manage all Quotation  with customer and quotation schedule details.</span>
            </div>
        </div>

        <div class="flex items-center flex-wrap gap-1.5 lg:gap-2">

            <div class="">
                <label class="input input-md">
                    <i class="ki-filled ki-magnifier"></i>
                    <input data-datatable-search="#TableQuotation" placeholder="Search Quotation No..." type="text" id="txtSearchDisplay" />
                </label>
            </div>
            <button class="btn btn-md text-md btn-outline original btn-light dropdown-toggle" data-drawer-toggle="#drawer_4">
                <i class="ki-filled ki-setting-4">
                </i>
                Filters
                @{
                    int count = Model.GetFilterCount();
                    if (count > 0)
                    {
                        <span class="badge text-2xs badge-xs batch-new badge-primary">
                            @count
                        </span>
                    }
                }

            </button>
            @Html.Partial("_CustomizeColumn", 8)

        </div>

    </div>
</div>
@{
    var ActiveTab = PageSessionManager.GetAttribute<int>(PageKeys.Quotation, "ActiveTab", 0);
}
<div class="container-fluid">
    <div class="grid">
        <div class="flex gap-3 justify-between">
            <div class="card-summary-flat">
                <a data-tooltip='#tooltip_C_0' class="card-stat @(ActiveTab == 0 ? "active" : "")" href="@Url.Action("ListStatus", "Booking", new { status = 0 })">
                    <span class="header">All Quotation</span>
                    <span class="stat-count">@Common.FormatNumberInteger(Model.StatusCount.Sum(x => x.status_count))</span>
                </a>
                <a data-tooltip='#tooltip_C_1' class="card-stat @(ActiveTab == 1 ? "active" : "")" href="@Url.Action("ListStatus", "Booking", new { status = 1 })">
                    <span class="header">Draft</span>
                    <span class="stat-count">@Common.FormatNumberInteger(Model.StatusCount.Where(x => x.status_code == 1).Sum(x => x.status_count))</span>
                </a>
                <a data-tooltip='#tooltip_C_1' class="card-stat @(ActiveTab == 2 ? "active" : "")" href="@Url.Action("ListStatus", "Booking", new { status = 2 })">
                    <span class="header">HOD Approval</span>
                    <span class="stat-count">@Common.FormatNumberInteger(Model.StatusCount.Where(x => x.status_code == 2).Sum(x => x.status_count))</span>
                </a>
                <a data-tooltip='#tooltip_C_1' class="card-stat @(ActiveTab == 3 ? "active" : "")" href="@Url.Action("ListStatus", "Booking", new { status = 3 })">
                    <span class="header">Approved</span>
                    <span class="stat-count">@Common.FormatNumberInteger(Model.StatusCount.Where(x => x.status_code == 3).Sum(x => x.status_count))</span>
                </a>
                <a data-tooltip='#tooltip_C_1' class="card-stat @(ActiveTab == 4 ? "active" : "")" href="@Url.Action("ListStatus", "Booking", new { status = 4 })">
                    <span class="header">Rejected</span>
                    <span class="stat-count">@Common.FormatNumberInteger(Model.StatusCount.Where(x => x.status_code == 4).Sum(x => x.status_count))</span>
                </a>

            </div>
            @*<div class="mycountswitch">
                    <label class="switch">
                        <span class="switch-label">
                            Show My Quotes Only
                        </span>
                        <input name="check" type="checkbox" value="1" />
                    </label>
                </div>*@
        </div>
        <div class="card card-grid min-w-full">

            <div class="card-body">
                <div id="TableQuotation" class="custom-dt">
                    <div class="scrollable-x-auto">
                        <table class="table table-auto table-border align-middle"
                               data-datatable-table="true">
                            <thead>
                                <tr>
                                    <th class="min-w-[220px]" data-datatable-column="quotationno">
                                        <span class="sort">
                                            <span class="sort-label">
                                                Quotation No
                                            </span>
                                            <span class="sort-icon">
                                            </span>
                                        </span>
                                    </th>
                                    <th class="min-w-[150px]" data-datatable-column="quoteDate">
                                        <span class="sort">
                                            <span class="sort-label">
                                                Quote Date
                                            </span>
                                            <span class="sort-icon">
                                            </span>
                                        </span>
                                    </th>
                                    @*<th class="min-w-[150px]" data-datatable-column="billto">
                                        <span class="sort">
                                            <span class="sort-label">
                                                Bill To
                                            </span>
                                            <span class="sort-icon">
                                            </span>
                                        </span>
                                    </th>*@
                                    <th class="min-w-[150px]" data-datatable-column="customername">
                                        <span class="sort">
                                            <span class="sort-label">
                                                Customer Name
                                            </span>
                                            <span class="sort-icon">
                                            </span>
                                        </span>
                                    </th>
                                    <th class="min-w-[150px]" data-datatable-column="totalamount">
                                        <span class="sort">
                                            <span class="sort-label">
                                                Amount
                                            </span>
                                            <span class="sort-icon">
                                            </span>
                                        </span>
                                    </th>
                                    <th class="min-w-[150px]" data-datatable-column="expiryDate">
                                        <span class="sort">
                                            <span class="sort-label">
                                                Expiry Date
                                            </span>
                                            <span class="sort-icon">
                                            </span>
                                        </span>
                                    </th>
                                    <th class="min-w-[150px]" data-datatable-column="createdby">
                                        <span class="sort">
                                            <span class="sort-label">
                                                Created By
                                            </span>
                                            <span class="sort-icon">
                                            </span>
                                        </span>
                                    </th>
                                    <th class="min-w-[150px] text-center" data-datatable-column="status">
                                        Status
                                    </th>
                                    <th data-datatable-column="action" class="text-center w-[80px]">Action</th>
                                </tr>
                            </thead>
                        </table>
                    </div>
                    <div class="card-footer justify-center md:justify-between flex-col md:flex-row gap-3 text-gray-600 text-2sm font-medium">
                        <div class="flex items-center gap-2">
                            Show
                            <select class="select select-sm w-16" data-datatable-size="true" name="perpage">
                            </select>
                            per page
                        </div>
                        <div class="flex items-center gap-4">
                            <span data-datatable-info="true"></span>
                            <div class="pagination" data-datatable-pagination="true"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @using (Html.BeginForm("QuotationList", "Booking", FormMethod.Post, new { @id = "frmQuotationList" }))
    {
        <div class="drawer drawer-end flex flex-col gap-4 filter-width" data-drawer="true" id="drawer_4">
            <div class="flex items-center justify-between p-5 border-b">
                <h3 class="text-base font-semibold text-gray-900">
                    Filters
                </h3>
                <button class="btn btn-xs btn-icon btn-light" data-drawer-dismiss="true">
                    <i class="ki-outline ki-cross">
                    </i>
                </button>
            </div>
            <div class="scrollable-y py-0 px-5">
                <div class=" grid lg:grid-cols-2 gap-5">
                    <div class="w-full grid-2">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                Booking Number
                            </label>
                            <div class="input-group w-full">
                                @Html.TextBoxFor(m => m.filters.bookingno, new { @id = "txtponumber", @placeholder = "Enter Booking Number", @class = "form-control input", @datarequired = "no" })
                            </div>
                        </div>
                    </div>
                    <div class="w-full grid-2">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                Company
                            </label>
                            <div class="input-group w-full">
                                @Html.ListBoxFor(m => m.filters.agencyuuids, new SelectList(@ViewBag.AgenciesUUIDDropdown, "Value", "Text", "") { }, new { @id = "ddlAgencyIDs", @placeholder = "Enter Company to search", @class = "form-control select2", @datarequired = "no", @datarequired_message = "Please select Port", @data_append_parent = "yes", @style = "width:100%;", @multiple = true })
                            </div>
                        </div>
                    </div>
                    <div class="w-full grid-2">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                Created By
                            </label>
                            <div class="input-group w-full">
                                @Html.ListBoxFor(m => m.filters.createdby, new SelectList(@ViewBag.CreatedByDropdown, "Value", "Text", "") { }, new { @id = "ddlcreatedby", @placeholder = "Enter User to search", @class = "form-control select2", @datarequired = "no", @datarequired_message = "Please select Port", @data_append_parent = "yes", @style = "width:100%;", @multiple = true })
                            </div>
                        </div>
                    </div>
                    <div class="w-full grid-2">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                HOD Approver (Assigned to)
                            </label>
                            <div class="input-group w-full">
                                @Html.DropDownListFor(m => m.filters.hodapprover_enc, new SelectList(@ViewBag.HODApprovalUserDropdown, "Value", "Text", "") { }, new { @id = "ddlhodapprover", @placeholder = "Enter User to search", @class = "form-control select2", @datarequired = "no", @datarequired_message = "Please select Port", @data_append_parent = "yes", @style = "width:100%;" })
                            </div>
                        </div>
                    </div>
                    <div class="w-full lg:col-span-2">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">Status</label>
                            <div class="input-group w-full">
                                @Html.DropDownListFor(m => m.filters.status, new SelectList(ViewBag.StatusDropdown, "Value", "Text"), "- All Statuses -", new { @id = "ddlStatus", @class = "form-control select2", @style = "width:100%;" })
                            </div>
                        </div>
                    </div>

                </div>
            </div>
            <div class="flex justify-between">
                <div class="flex justify-end gap-4 border-t p-5">
                    <button type="button" class="btn btn-light" data-drawer-dismiss="true">
                        Cancel
                    </button>
                </div>
                <div class="flex justify-end gap-4 border-t p-5">
                    <button type="submit" name="action" value="Reset" class="btn btn-light" data-drawer-dismiss="true">
                        Reset Filter
                    </button>
                    <button type="submit" name="action" value="filter" class="btn btn-dark">
                        Apply Filter
                    </button>
                </div>
            </div>
        </div>

    }
</div>
<div id="modalsection"></div>

@section PageScripts {
    <script src="~/js/ContainerBooking/QuotationList.js?v=1.0.1"></script>
    <script src="~/js/port.js"></script>
    <script src="~/js/customizecolumn.js?v=1.0.0"></script>
}
