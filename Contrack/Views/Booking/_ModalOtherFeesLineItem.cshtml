@using Contrack
@model OtherFeesDTO

<div class="modal" data-modal="true" data-modal-backdrop-static="true" data-modal-autofocus="true" id="ModalOtherFeeLineItem">
    <div class="modal-content modal-center-y max-w-[600px] max-h-[95%]">
        <div class="modal-header">
            <h3 class="modal-title">
                @(string.IsNullOrEmpty(Model.otherfeeuuid) ? "Add Line Item" : "Edit Line Item")
            </h3>
            <button class="btn btn-xs btn-icon btn-light" data-modal-dismiss="true">
                <i class="ki-outline ki-cross"></i>
            </button>
        </div>

        <div class="modal-body scrollable-y">
            <div class="model-req flex items-center grow rounded-xl border border-dashed gap-4 p-2 mb-3 border-primary bg-primary-light">
                <i class="ki-outline ki-information-1 text-3xl text-primary"></i>
                <div class="flex flex-col gap-0.5">
                    <p class="text text-2sm font-normal">
                        Fields marked with <span class="text-danger">*</span> are mandatory.
                    </p>
                </div>
            </div>

            <form id="formQuotationLineItem">
                @Html.HiddenFor(m => m.otherfeeuuid)
                <div class="flex flex-col gap-5">
                    <div class="flex flex-col1 items-baseline gap-1.5">
                        <label class="form-label max-w-[170px]">
                            Charge Name <span class="text-danger ps-2">*</span>
                        </label>
                        <div class="flex flex-col w-full">
                            @Html.TextBoxFor(m => m.chargename, new
                            {
                                @class = "input",
                                @placeholder = "Enter Charge Name",
                                @datarequired = "yes",
                                @datarequired_message = "Please enter Charge Name"
                            })
                        </div>
                    </div>

                    <div class="flex flex-col1 items-baseline gap-1.5">
                        <label class="form-label max-w-[170px]">
                            Amount <span class="text-danger ps-2">*</span>
                        </label>
                        <div class="flex flex-col1 w-full gap-2.5 items-stretch justify-between">
                            @Html.TextBoxFor(m => m.amount, new
                            {
                                @class = "input text-end focus-input",
                                @placeholder = "0.00",
                                @datarequired = "yes",
                                @datarequired_message = "Please enter Amount"
                            })

                            @Html.DropDownListFor(
                                m => m.uom,
                                new SelectList(Common.AlterUOM(ViewBag.UOMDropdown, Model.uom), "Value", "Text", Model.uom),
                                new
                                {
                                    @id = "ddlUOM",
                                    @class = "form-control select",
                                    @datarequired = "yes",
                                    @datarequired_message = "Please select UOM"
                                })
                        </div>
                    </div>

                    <div class="flex flex-col1 items-baseline gap-1.5">
                        <label class="form-label max-w-[170px]">
                            Remarks
                        </label>
                        <div class="flex flex-col w-full">
                            @Html.TextAreaFor(m => m.remarks, new
                            {
                                @class = "textarea",
                                @rows = "4"
                            })
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <div class="modal-footer justify-end">
            <div class="flex gap-3">
                <button class="btn btn-light" data-modal-dismiss="true">
                    Close
                </button>
                <button class="btn btn-primary" onclick="SaveOtherFeesLineItem();">
                    Save
                </button>
            </div>
        </div>
    </div>
</div>