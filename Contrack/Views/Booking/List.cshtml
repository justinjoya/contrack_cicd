                <span class="header">All Bookings</span>
                <span class="stat-count">@Common.FormatNumberInteger(Model.StatusCount.Sum(x => x.StatusCount))</span>
                @Html.Partial("_ToolTip", new Tooltip()
                {
                    ID = "tooltip_B_0",
                    Message = "All bookings : " + Model.StatusCount.Sum(x => x.StatusCount)
                })
            </a>

            <a data-tooltip='#tooltip_B_1' class="card-stat @(ActiveTab == 1 ? "active" : "")"
               href="@Url.Action("BookingListStatus", "Booking", new { status = 1 })">
