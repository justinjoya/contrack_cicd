@model Contrack.BookingListFilter
@using Contrack

@{
    ViewBag.Title = "Container Booking";
    ViewBag.MainManu = "Booking";
    ViewBag.SubManu = "Container Booking";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="breadscrumb-holder">
    <div class="container-fluid flex items-center justify-between flex-wrap gap-5">

        <div class="flex flex-col justify-center items-start flex-wrap gap-1 lg:gap-2">

            <h1 class="page-header">Container Bookings</h1>
            <div class="flex items-center gap-1 text-sm font-normal">
                <span class="text-gray-700">Manage all container bookings with customer, vessel, route, and schedule details.</span>
            </div>
        </div>

        <div class="flex items-center flex-wrap gap-1.5 lg:gap-2">

            <div class="">
                <label class="input input-md">
                    <i class="ki-filled ki-magnifier"></i>
                    <input data-datatable-search="#TableContainerBooking" placeholder="Search Booking No..." type="text" id="txtSearchDisplay" />
                </label>
            </div>

            <button class="btn btn-md text-md btn-outline original btn-light dropdown-toggle" data-drawer-toggle="#drawer_4">
                <i class="ki-filled ki-setting-4">
                </i>
                Filters
                @{
                    int count = Model.GetFilterCount();
                    if (count > 0)
                    {
                        <span class="badge text-2xs badge-xs batch-new badge-primary">
                            @count
                        </span>
                    }
                }

            </button>
            @Html.Partial("_CustomizeColumn", 7)
            <a href="@Url.Action("CustomerSelection", "Booking")" class="btn btn-md text-md btn-primary">
                <i class="ki-filled ki-plus"></i>
                Create Booking
            </a>
        </div>

    </div>
</div>
@{
