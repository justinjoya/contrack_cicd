@model Contrack.ContainerBooking

<div class="w-full">
    <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
        <label class="form-label flex items-center gap-1 max-w-56">
            Consignee PIC <span class="text-danger ps-2">*</span>
        </label>
        @Html.DropDownListFor(
            m => m.booking.location.consigneepic.EncryptedValue,
            new SelectList(
                ViewBag.ConsigneePICDropdown,
                "Value",
                "Text",
                Model.booking.location.consigneepic.EncryptedValue
            ),
            "-Select-",
            new
            {
                @id = "ddlConsigneePIC",
                @class = "form-control select2",
                @datarequired = "yes",
                @datarequired_message = "Please select Consignee PIC",
                @style = "width:100%;",
                @data_append_parent = "yes"
            }
        )
    </div>
</div>
