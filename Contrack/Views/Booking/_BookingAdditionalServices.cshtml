@using Contrack
@model ContainerBooking

<style>
    .additional-services-holder {
        background: transparent;
        padding: 0;
    }

    .header {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 12px;
    }

    .tabs {
        display: flex;
        justify-content: center;
        gap: 12px;
        margin-bottom: 16px;
    }

    .tab-btn {
        padding: 8px 28px;
        border-radius: 20px;
        border: 1px solid #dcdcdc;
        background: #f5f5f5;
        cursor: pointer;
        font-weight: 500;
    }

        .tab-btn.active {
            background: #2563eb;
            color: #fff;
            border-color: #2563eb;
        }

    .tab-content {
        display: none;
    }

        .tab-content.active {
            display: block;
        }

    /*    .service-items {
        background: #ffffff;
        border-radius: 10px;
        padding: 16px;
    }*/

    .service-item {
        display: grid;
        grid-template-columns: 1fr 220px;
        gap: 16px;
        padding: 12px 0;
        border-bottom: 1px solid #eee;
        align-items: center;
    }

        .service-item:last-child {
            border-bottom: none;
        }

    .item-info {
        display: flex;
        flex-direction: column;
    }

    .item-name {
        font-weight: 600;
    }

    .item-desc {
        font-size: 12px;
        color: #666;
    }

    .additional-service-check {
        width: 18px;
        height: 18px;
        transform: scale(1.3);
        margin-right: 8px;
        cursor: pointer;
    }

    .item-input {
        min-width: 220px;
    }
</style>

@{
    var polServices = Model.booking.additionalservices ?? new List<BookingAdditionalServicesDTO>();
    var podServices = Model.booking.PODadditionalservices ?? new List<BookingAdditionalServicesDTO>();
    var uomList = ViewBag.UOMDropdown;
}

@if (polServices.Any() || podServices.Any())
{
    <div class="additional-services-holder">
        <div class="header">Additional Services</div>

        @*<div class="menu gap-3" data-menu="true">
                <div class="menu-item border-b-2 border-b-transparent menu-item-active:border-b-primary menu-item-here:border-b-primary here">
                    <a class="menu-link gap-1.5 pb-2 lg:pb-4 px-2" href="javascript:void(0);">
                        <span class="menu-title text-nowrap font-medium text-sm text-gray-700 menu-item-active:text-primary menu-item-active:font-medium menu-item-here:text-primary menu-item-here:font-medium menu-item-show:text-primary menu-link-hover:text-primary">
                            POL
                        </span>
                    </a>
                </div>
                <div class="menu-item border-b-2 border-b-transparent menu-item-active:border-b-primary menu-item-here:border-b-primary ">
                    <a class="menu-link gap-1.5 pb-2 lg:pb-4 px-2" href="javascript:void(0);">
                        <span class="menu-title text-nowrap font-medium text-sm text-gray-700 menu-item-active:text-primary menu-item-active:font-semibold menu-item-here:text-primary menu-item-here:font-semibold menu-item-show:text-primary menu-link-hover:text-primary">
                            POD
                        </span>
                    </a>
                </div>
            </div>*@

        <div class="tabs" id="additionalservicetab">
            <button type="button" class="tab-btn active" data-tab="polTab">POL</button>
            <button type="button" class="tab-btn" data-tab="podTab">POD</button>
        </div>

        <div id="polTab" class="active tabcontent">
            <div class="service-items">
                @for (int i = 0; i < polServices.Count; i++)
                {
                    var service = polServices[i];
                    bool isChecked = service.bookingadditionalserviceid.NumericValue > 0;
                    @Html.Hidden("booking.additionalservices.index", i)
                    <div class="service-item additional-service-row">
                        @Html.HiddenFor(m => m.booking.additionalservices[i].additionalserviceid.EncryptedValue, new { @class = "service-input" })
                        @Html.HiddenFor(m => m.booking.additionalservices[i].locationtypeid.EncryptedValue, new { @class = "service-input" })
                        <label>
                            <input type="checkbox" class="checkbox checkbox-sm additional-service-check" @(isChecked ? "checked" : "") />
                            <span class="item-info">
                                <span class="item-name">@service.servicename</span>
                                <span class="item-desc">@service.description</span>
                            </span>
                        </label>
                        <div class="item-input">
                            <span class="input-label">UOM</span>
                            @Html.DropDownListFor(m => m.booking.additionalservices[i].uom, new SelectList(Common.AlterUOM(uomList, service.uom), "Value", "Text", service.uom), new { @class = "form-control select2 additional-service-uom service-input", disabled = !isChecked })
                        </div>
                    </div>
                }
            </div>
        </div>

        <div id="podTab" class="tabcontent" style="display:none;">
            <div class="service-items">
                @for (int i = 0; i < podServices.Count; i++)
                {
                    var service = podServices[i];
                    bool isChecked = service.bookingadditionalserviceid.NumericValue > 0;
                    @Html.Hidden("booking.PODadditionalservices.index", i)
                    <div class="service-item additional-service-row">
                        @Html.HiddenFor(m => m.booking.PODadditionalservices[i].additionalserviceid.EncryptedValue, new { @class = "service-input" })
                        @Html.HiddenFor(m => m.booking.PODadditionalservices[i].locationtypeid.EncryptedValue, new { @class = "service-input" })
                        <label>
                            <input type="checkbox" class="checkbox checkbox-sm additional-service-check" @(isChecked ? "checked" : "") />
                            <span class="item-info">
                                <span class="item-name">@service.servicename</span>
                                <span class="item-desc">@service.description</span>
                            </span>
                        </label>
                        <div class="item-input">
                            <span class="input-label">UOM</span>
                            @Html.DropDownListFor(m => m.booking.PODadditionalservices[i].uom, new SelectList(Common.AlterUOM(uomList, service.uom), "Value", "Text", service.uom), new { @class = "form-control select2 additional-service-uom service-input", disabled = !isChecked })
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
