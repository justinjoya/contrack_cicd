@model Contrack.ContainerBookingDetailDTO
@using Contrack;

@{
    var shuntingServices = ViewBag.ShuntingServices as List<ShuntingServiceDTO>;
    var selectedServiceIds = Model.services?
        .Select(x => x.serviceid.EncryptedValue)
        .ToList() ?? new List<string>();

    int index = 0;
}


<div class="modal" data-modal="true" data-modal-backdrop-static="true" data-modal-autofocus="true" id="ModalAddBookingContainer">
    <div class="modal-content modal-center-y max-w-[800px] max-h-[95%]">
        <div class="modal-header">
            <h3 class="modal-title">
                @(Model.bookingdetailid.NumericValue == 0 ? "Add Container" : "Edit Container")
            </h3>
            <button class="btn btn-xs btn-icon btn-light" data-modal-dismiss="true">
                <i class="ki-outline ki-cross"></i>
            </button>
        </div>

        <div class="modal-body scrollable-y">
            @*<div class="model-req flex items-center grow rounded-xl border border-dashed gap-4 p-2 mb-3 border-primary bg-primary-light">
                    <i class="ki-outline ki-information-1 text-3xl text-primary"></i>
                    <div class="flex flex-col gap-0.5">
                        <p class="text text-2sm font-normal">
                            Fields marked with <span class="text-danger"> * </span> are mandatory.
                        </p>
                    </div>
                </div>*@

            <form id="formAddBookingContainer">

                @Html.HiddenFor(m => m.bookingdetailuuid)
                @Html.HiddenFor(m => m.bookingid.EncryptedValue)

                @*<div class="w-full grid-2">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1">
                                Ownership <span class="text-danger"> * </span>
                            </label>
                            <div class="ownership flex items-center gap-3">
                                <label class="type-option">
                                    <input type="radio" name="ownType" checked />
                                    <span class="chip">Owned</span>
                                    <img src="~/assets/img/tick-circle.svg" />
                                </label>

                                <label class="type-option">
                                    <input type="radio" name="ownType" />
                                    <span class="chip">Leased</span>
                                    <img src="~/assets/img/tick-circle.svg" />
                                </label>

                                <label class="type-option">
                                    <input type="radio" name="ownType" />
                                    <span class="chip">SOC</span>
                                    <img src="~/assets/img/tick-circle.svg" />
                                </label>

                                <label class="type-option">
                                    <input type="radio" name="ownType" />
                                    <span class="chip">COC</span>
                                    <img src="~/assets/img/tick-circle.svg" />
                                </label>
                            </div>
                        </div>
                    </div>*@
                <div class="w-full grid-2">
                    <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                        <label class="form-label flex items-center gap-1">
                            Ownership <span class="text-danger"> * </span>
                        </label>

                        <div class="ownership flex items-center gap-3">
                            @foreach (var item in (List<SelectListItem>)ViewBag.OwnershipList)
                            {
                                var isChecked = Model.ownership == Common.ToInt(item.Value) || (Model.ownership == 0 && item.Value == "1");
                                <label class="type-option">
                                    <input type="radio" name="ownership" value="@item.Value" @(isChecked ? "checked" : "") />
                                    <span class="chip">@item.Text</span>
                                    <img src="~/assets/img/tick-circle.svg" />
                                </label>
                            }
                        </div>
                    </div>
                </div>

                <div class="grid lg:grid-cols-3 items-stretch gap-5 mt-5">
                    <div class="w-full">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                Container Type <span class="text-danger">*</span>
                            </label>
                            <div class="flex flex-col w-full">
                                @Html.DropDownListFor(m => m.containertypeid.EncryptedValue, new SelectList(@ViewBag.ContainerType, "Value", "Text", "") { }, new { @id = "ddlcontainertype", @placeholder = "Select ", @class = "form-control select2", @datarequired = "yes", @datarequired_message = "Please choose ContainerType", @data_append_parent = "yes" })

                            </div>

                        </div>
                    </div>
                    <div class="w-full">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                Container Size <span class="text-danger">*</span>
                            </label>
                            <div class="flex flex-col w-full">

                                @Html.DropDownListFor(m => m.sizeid.EncryptedValue, new SelectList(@ViewBag.ContainerSize, "Value", "Text", "") { }, new { @id = "ddlcontainersize", @placeholder = "Select ", @class = "form-control select2", @datarequired = "yes", @datarequired_message = "Please choose ContainerType", @data_append_parent = "yes" })

                            </div>
                        </div>
                    </div>

                    <div id="containermodel_container"
                         class="flex flex-col items-baseline gap-2.5">
                        @*style="@(string.IsNullOrEmpty(Model.containermodeluuid) ? "" : "display:none")">*@
                        @Html.Partial("_ContainerModelDropdown", Model)
                    </div>

                    <div class="w-full">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                Empty / Full <span class="text-danger">*</span>
                            </label>
                            <div class="flex flex-col w-full">
                                @Html.DropDownListFor(m => m.empty_full, new SelectList(ViewBag.emptyorfull, "Value", "Text", ""), new { @id = "ddlEmptyOrFull", @class = "form-control select2", @style = "width:100%;", @datarequired = "yes", @datarequired_message = "Please choose Empty/Full", @data_append_parent = "yes" })
                            </div>
                        </div>
                    </div>

                    <div class="w-full">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                Quantity
                            </label>
                            <div class="input-group w-full">
                                <button type="button" id="btnDeliveryDate" class="btn btn-icon btn-outline btn-icon-lg btn-light">
                                    <i class="ki-filled ki-minus"></i>
                                </button>
                                @Html.TextBoxFor(m => m.qty, new { @class = "input text-center focus-input", @placeholder = "0", @datarequired = "yes", @datarequired_message = "Please enter quantity greater than 0", @id = "txt_Qty", @min = "1", @datatype = "number" })
                                <button type="button" id="btnClearDeliveryDate" class="btn btn-danger1 btn-icon btn-outline btn-icon-lg btn-light">
                                    <i class="ki-filled ki-plus"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="w-full">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                Commodity <span class="text-danger" id="commodityRequiredStar" style="display:none">*</span>
                            </label>
                            @Html.TextBoxFor(m => m.commodity, new { @class = "input", @placeholder = "Commodity", @id = "txt_Commodity" })
                        </div>
                    </div>
                    <div class="w-full">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                Gross weight (kg)
                            </label>
                            @Html.TextBoxFor(m => m.grossweight, new { @class = "input focus-input", @placeholder = "grossweight", @datarequired = "no", @datarequired_message = "Please enter Gross weight", @id = "txt_GrossWeight" })
                        </div>
                    </div>
                    <div class="w-full">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                Volume (CBM)
                            </label>
                            @Html.TextBoxFor(m => m.volumeweight, new { @class = "input focus-input", @placeholder = "Volume", @datarequired = "no", @datarequired_message = "Please enter Volume(CBM)", @id = "txt_Volume" })
                        </div>
                    </div>
                    <div class="w-full">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                HS Code
                            </label>
                            @Html.TextBoxFor(m => m.hscode, new { @class = "input", @placeholder = "hsCode", @datarequired = "no", @datarequired_message = "Please enter HS Code", @id = "txt_HSCode" })
                        </div>
                    </div>
                    <div class="w-full">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                Cargo Value (USD)
                            </label>
                            @Html.TextBoxFor(m => m.cargovalue, new { @class = "input focus-input", @placeholder = "cargovalue", @datarequired = "no", @datarequired_message = "Please enter Cargo Value (USD)", @id = "txt_CargoValue" })
                        </div>
                    </div>
                    <div class="w-full">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                Packaging Type
                            </label>
                            <div class="flex flex-col w-full">
                                @Html.DropDownListFor(m => m.packagetype.EncryptedValue, new SelectList(ViewBag.PackageType, "Value", "Text", Model.packagetype.EncryptedValue), new { @id = "ddlpackagetype", @class = "form-control select2" })
                            </div>
                        </div>
                    </div>
                    <div class="w-full">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                Expected Stuffing Date
                            </label>
                            <div class="input-group w-full">
                                @Html.TextBoxFor(m => m.expectedstuffingdate.DBFormattedText, new { @data_trigger = "btnTarget", @class = "datepicker-here input", @placeholder = "dd/mm/yyyy", @id = "txt_DateTimePI", @data_provider = "flatpickr1", @data_clear = "btnClearDate", @readonly = true })
                                @*@Html.TextBoxFor(m => m.expectedstuffingdate,
                                        new
                                        {
                                            @class = "datetimepicker-here input",
                                            @placeholder = "dd/mm/yyyy hh:mm",
                                            @id = "txt_DateTimePI",
                                            @data_provider = "flatpickr1",
                                            @data_trigger = "btnTarget",
                                            @data_clear = "btnClearDate"
                                        }
                                    )*@

                                <button type="button" id="btnTarget" class="btn btn-icon btn-outline btn-icon-lg btn-light">
                                    <i class="ki-filled ki-calendar-2"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="w-full">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                Stuffing location
                            </label>
                            @Html.TextBoxFor(m => m.stuffinglocation, new { @class = "input", @placeholder = "stuffing location", @datarequired = "no", @datarequired_message = "Please enter Stuffing location", @id = "txt_Commodity" })
                        </div>
                    </div>
                    <div class="w-full">
                        <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                            <label class="form-label flex items-center gap-1 max-w-56">
                                Pick-up location
                            </label>
                            @Html.TextBoxFor(m => m.pickuplocation, new { @class = "input", @placeholder = "pickup location", @datarequired = "no", @datarequired_message = "Please enter Pick-up location", @id = "txt_Commodity" })
                        </div>
                    </div>
                    <!--<div class="w-full grid-2 margin-check">
                    <div class="flex flex-col items-baseline flex-wrap lg:flex-nowrap gap-2.5">-->
                    @*<label class="flex items-center gap-2">
                            <input type="checkbox" class="checkbox">
                            <span class="nowrap">Is this container DG or Reefer</span>
                        </label>*@
                    <!--</div>
                    </div>-->
                    <div></div>

                    @*<img class="border-img" src="~/assets/img/Vector 197.svg" />*@

                    @if (shuntingServices != null && shuntingServices.Any())
                    {
                        <div class="w-full">
                            <label class="form-label mb-3 block">Shunting Services:</label>
                            @{
                                var tblToSite = shuntingServices
                                    .Where(x => x.type.NumericValue == 1)
                                    .OrderBy(x => x.orderby)
                                    .ToList();
                            }

                            @if (tblToSite.Any())
                            {
                                <div class="flex items-center gap-6 mb-3">
                                    <span class="min-w-[110px] text-md text-gray-900">1. TBL to Site:</span>

                                    @foreach (var service in tblToSite)
                                    {
                                        var isChecked = selectedServiceIds.Contains(service.serviceid.EncryptedValue);

                                        <input type="hidden" name="services.index" value="@index" />

                                        <label class="flex items-center gap-2">
                                            <input type="checkbox"
                                                   class="checkbox checkbox-sm"
                                                   name="services[@index].serviceid.EncryptedValue"
                                                   value="@service.serviceid.EncryptedValue"
                                                   @(isChecked ? "checked" : "") />

                                            <span class="nowrap text-sm">@service.servicename</span>
                                        </label>

                                        index++;
                                    }
                                </div>
                            }

                            @{
                                var siteToTbl = shuntingServices
                                    .Where(x => x.type.NumericValue == 2)
                                    .OrderBy(x => x.orderby)
                                    .ToList();
                            }

                            @if (siteToTbl.Any())
                            {
                                <div class="flex items-center gap-6">
                                    <span class="min-w-[110px] text-md text-gray-900">2. Site to TBL:</span>

                                    @foreach (var service in siteToTbl)
                                    {
                                        var isChecked = selectedServiceIds.Contains(service.serviceid.EncryptedValue);

                                        <input type="hidden" name="services.index" value="@index" />

                                        <label class="flex items-center gap-2">
                                            <input type="checkbox"
                                                   class="checkbox checkbox-sm"
                                                   name="services[@index].serviceid.EncryptedValue"
                                                   value="@service.serviceid.EncryptedValue"
                                                   @(isChecked ? "checked" : "") />

                                            <span class="nowrap text-sm">@service.servicename</span>
                                        </label>

                                        index++;
                                    }
                                </div>
                            }
                        </div>
                    }

                </div>
            </form>
        </div>

        <div class="modal-footer justify-end">
            <div class="flex gap-4">
                <button class="btn btn-light" data-modal-dismiss="true">Close</button>
                <button class="btn btn-primary" id="btnSaveBookingContainer" onclick="SaveBookingContainer();">Save Container</button>
            </div>
        </div>
    </div>
</div>
