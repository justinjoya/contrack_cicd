@using Contrack
@model QuotationDetailDTO

<div class="modal" data-modal="true" data-modal-backdrop-static="true" data-modal-autofocus="true" id="ModalQuotationLineItem">
    <div class="modal-content modal-center-y max-w-[600px] max-h-[95%]">
        <div class="modal-header">
            <h3 class="modal-title">
                @(string.IsNullOrEmpty(Model.quotationdetailuuid) ? "Add Line Item" : "Edit Line Item")
            </h3>
            <button class="btn btn-xs btn-icon btn-light" data-modal-dismiss="true">
                <i class="ki-outline ki-cross"></i>
            </button>
        </div>

        <div class="modal-body scrollable-y">
            <div class="model-req flex items-center grow rounded-xl border border-dashed gap-4 p-2 mb-3 border-primary bg-primary-light">
                <i class="ki-outline ki-information-1 text-3xl text-primary"></i>
                <div class="flex flex-col gap-0.5">
                    <p class="text text-2sm font-normal">
                        Fields marked with <span class="text-danger">*</span> are mandatory.
                    </p>
                </div>
            </div>

            <form id="formQuotationLineItem">

                @Html.HiddenFor(m => m.quotationdetailuuid)
                @Html.HiddenFor(m => m.quotationdetailid.EncryptedValue)
                @Html.HiddenFor(m => m.quotationid.EncryptedValue)
                @Html.HiddenFor(m => m.createdat)
                @Html.HiddenFor(m => m.templateprice, new { @id = "hdn_templateprice" })
                @Html.HiddenFor(m => m.TypeSizeCombinedText, new { @id = "TypeSizeCombinedText" })

                <div class="flex flex-col gap-5">
                    <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                        <label class="form-label max-w-[170px]">
                            Container Type <span class="text-danger ps-2">*</span>
                        </label>
                        <div class="flex flex-col w-full">
                            @Html.DropDownListFor(
                                m => m.TypeSizeCombinedValue,
                                new SelectList(ViewBag.ContainerTypeSizeDropdown, "Value", "Text", ""),
                                new
                                {
                                    @id = "ddlTypeSizeCombinedValue",
                                    @class = "form-control select2",
                                    @style = "width:100%;",
                                    @datarequired = "no",
                                    @datarequired_message = "Please select Container Type"
                                })
                        </div>
                    </div>
                    @Html.HiddenFor(m => m.fullempty)
                    @*<div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                            <label class="form-label max-w-[170px]">
                                Empty / Full <span class="text-danger ps-2">*</span>
                            </label>
                            <div class="flex flex-col w-full">
                                @Html.DropDownListFor(
                                    m => m.fullempty,
                                    new SelectList(ViewBag.FullEmptyDropdown, "Value", "Text", ""),
                                    new
                                    {
                                        @id = "ddlFullEmpty",
                                        @class = "form-control select2",
                                        @style = "width:100%;",
                                        @datarequired = "yes",
                                        @datarequired_message = "Please select Empty/Full"
                                    })
                            </div>
                        </div>*@


                    <div class="flex flex-col gap-5">
                        <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5 existing">
                            <label class="form-label max-w-[170px]">
                                Description <span class="text-danger ps-2">*</span>
                            </label>
                            <div class="flex flex-col w-full">
                                @Html.DropDownListFor(
                                    m => m.jobtypedetailuuid,
                                    new SelectList(ViewBag.JobTypeDetailDropdown, "Value", "Text", Model.jobtypedetailuuid),
                                    new
                                    {
                                        @id = "ddlJobTypeDetailUUID",
                                        @class = "form-control select2",
                                        @style = "width:100%;",
                                        @datarequired = "yes",
                                        @datarequired_message = "Please select Description",
                                        @onchange = "FillDescription(this);"
                                    })
                            </div>
                        </div>

                        <div class="flex flex-col1 items-baseline gap-1.5 newitem" style="display:none">
                            @Html.TextAreaFor(
                                m => m.description,
                                new
                                {
                                    @id = "txtDescription",
                                    @class = "textarea",
                                    @rows = "4"
                                })
                        </div>
                    </div>

                    <div class="flex flex-col1 items-baseline gap-1.5">
                        <label class="form-label max-w-[170px]">
                            Quantity <span class="text-danger ps-2">*</span>
                        </label>
                        <div class="flex flex-col1 w-full gap-2.5 items-stretch justify-between">
                            @Html.TextBoxFor(m => m.qty, new { @class = "input text-end focus-input", @placeholder = "0.00", @datarequired = "yes", @datarequired_message = "Please enter Quantity" })

                            @Html.DropDownListFor(m => m.uom, new SelectList(Common.AlterUOM(ViewBag.UOMDropdown, Model.uom), "Value", "Text", Model.uom), new { @id = "ddlUOM", @class = "form-control select", @datarequired = "yes", @datarequired_message = "Please select UOM" })
                        </div>
                    </div>

                    <div class="flex flex-col1 items-baseline gap-1.5">
                        <label class="form-label max-w-[170px]">
                            Amount <span class="text-danger ps-2">*</span>
                        </label>
                        <div class="flex flex-col w-full">
                            @Html.TextBoxFor(m => m.amount, new { @id = "ddlAmount", @class = "input text-end focus-input", @placeholder = "0.00", @datarequired = "yes", @datarequired_message = "Please enter Amount" })
                        </div>
                    </div>

                    <div class="flex flex-col1 items-baseline gap-1.5">
                        <label class="form-label max-w-[170px]">
                            Tax <span class="text-danger ps-2">*</span>
                        </label>
                        <div class="flex flex-col w-full">
                            @Html.TextBoxFor(m => m.tax, new { @class = "input text-end focus-input", @placeholder = "0.00", @datarequired = "yes", @datarequired_message = "Please enter tax %" })
                        </div>
                    </div>

                    <div class="flex flex-col1 items-baseline gap-1.5">
                        <label class="form-label max-w-[170px]">
                            Remarks
                        </label>
                        <div class="flex flex-col w-full">
                            @Html.TextAreaFor(m => m.remarks, new { @class = "textarea", @rows = "4" })
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <div class="modal-footer justify-end">
            <div class="flex gap-3">
                <button class="btn btn-light" data-modal-dismiss="true">
                    Close
                </button>
                <button class="btn btn-primary" onclick="SaveQuotationLineItem();">
                    Save
                </button>
            </div>
        </div>

    </div>
</div>
