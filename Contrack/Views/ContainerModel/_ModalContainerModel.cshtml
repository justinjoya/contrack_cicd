@model Contrack.ContainerModel
@using Contrack;

<div class="modal" data-modal="true" data-modal-backdrop-static="true"
     data-modal-autofocus="true" id="ModalAddContainerModel">

    <div class="modal-content modal-center-y max-w-[600px] max-h-[95%]">
        <div class="modal-header">
            <h3 class="modal-title">
                @(Model.containermodel.modelid.NumericValue == 0 ? "Add Container Model" : "Edit Container Model")
            </h3>
            <button class="btn btn-xs btn-icon btn-light" data-modal-dismiss="true">
                <i class="ki-outline ki-cross"></i>
            </button>
        </div>

        <div class="modal-body scrollable-y h-[300px] max-h-[95%]">

            <div class="model-req flex items-center grow rounded-xl border border-dashed gap-4 p-2 mb-5 border-primary bg-primary-light">
                <i class="ki-outline ki-information-1 text-3xl text-primary"></i>
                <div class="flex flex-col gap-0.5">
                    <p class="text">
                        Fields marked with <span class="text-danger ps-2">*</span> are mandatory.
                    </p>
                </div>
            </div>

            <form id="formContainerModel">

                @Html.HiddenFor(m => m.containermodel.modelid.EncryptedValue)
                @Html.HiddenFor(m => m.containermodel.modeluuid)

                <div class="grid lg:grid-cols-1 items-stretch gap-5">

                    <!-- Container Type -->
                    <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                        <label class="form-label max-w-32 text-right">
                            Container Type <span class="text-danger ps-2">*</span>
                        </label>
                        <div class="flex w-full">
                            @Html.DropDownListFor(m => m.containermodel.typeid.EncryptedValue, new SelectList(ViewBag.ContainerTypesDropdown, "Value", "Text", ""),
                                new { @class = "input select2", @placeholder = "Select Container Type", @datarequired = "yes", @datarequired_message = "Please select Container Type", @id = "ddlContainerType", @style = "width:100%;" })
                        </div>
                    </div>

                    <!-- Container Size -->
                    <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                        <label class="form-label max-w-32 text-right">
                            Container Size <span class="text-danger ps-2">*</span>
                        </label>
                        <div class="flex w-full">
                            @Html.DropDownListFor(m => m.containermodel.sizeid.EncryptedValue, new SelectList(ViewBag.ContainerSizesDropdown, "Value", "Text", ""),
                                new { @class = "input select2", @placeholder = "Select Size", @datarequired = "yes", @datarequired_message = "Please select Size", @id = "ddlContainerSize", @style = "width:100%;" })
                        </div>
                    </div>

                    <!-- ISO Code -->
                    <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                        <label class="form-label max-w-32 text-right">
                            ISO Code <span class="text-danger ps-2">*</span>
                        </label>
                        <div class="flex flex-col w-full">
                            @Html.TextBoxFor(
                                m => m.containermodel.iso_code,
                                new
                                     {
                                    @class = "input",
                                    @placeholder = "Enter ISO Code",
                                    @datarequired = "yes",
                                    @datarequired_message = "Please enter ISO Code",
                                    @maxlength = "50"
                                }
                            )
                        </div>
                    </div>

                    <!-- Description -->
                    <div class="flex flex-col1 items-baseline flex-wrap lg:flex-nowrap gap-1.5">
                        <label class="form-label max-w-32 text-right">
                            Description
                        </label>
                        <div class="flex flex-col w-full">
                            @Html.TextAreaFor(
                                m => m.containermodel.description,
                                new
                                     {
                                    @class = "textarea",
                                    @rows = "4",
                                    @placeholder = "Enter description (optional)",
                                    @datarequired = "no"
                                }
                            )
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <div class="modal-footer justify-end">
            <div class="flex gap-4">
                <button class="btn btn-light" data-modal-dismiss="true">Close</button>
                <button class="btn btn-primary" onclick="SaveContainerModel();">
                    Save Container Model
                </button>
            </div>
        </div>

    </div>
</div>
