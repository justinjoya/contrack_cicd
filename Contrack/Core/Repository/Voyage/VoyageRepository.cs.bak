    public class VoyageRepository : CustomException, IVoyageRepository
    {
        public Result SaveVoyage(VoyageExtendedDTO voyage)
        {
            Result result = new Result();
            try
            {
                using (SqlDB Db = new SqlDB(DatabaseCollection.Contrack))
                {
                    var header = new
                    {
                        voyageid = Common.Decrypt(voyage.VoyageId.EncryptedValue),
                        voyagenumber = voyage.VoyageNumber,
                        vesseldetailid = Common.Decrypt(voyage.VesseDetailId.EncryptedValue),
                        description = voyage.Description,
                        voyageuuid = voyage.VoyageUuid,
                    };
                    string headerJson = System.Text.Json.JsonSerializer.Serialize(header);
                    var d = voyage.VoyageDetails;
                    var detail = new
                    {
                        voyagedetailid = Common.Decrypt(d.VoyageDetailId.EncryptedValue),
                        portid = Common.Decrypt(d.PortId.EncryptedValue),
                        terminal = d.Terminal,
                        eta = d.ETA.DBFormattedText,
                        etd = d.ETD.DBFormattedText,
                        cutoffdeadline = d.CutoffDeadline.DBFormattedText,
                        arrivalcaptain = d.ArrivalCaptain,
                        departurecaptain = d.DepartureCaptain,
                        isdeleted = false
                    };
                    string detailsJson = System.Text.Json.JsonSerializer.Serialize(new[] { detail });
                    string query = @"SELECT * FROM masters.voyage_save(
                    p_header_json  := '" + Common.Escape(headerJson) + @"',
                    p_details_json := '" + Common.Escape(detailsJson) + @"',
                    p_hub_id       := '" + Common.HubID + @"',
                    p_user_id      := '" + Common.LoginID + @"');";

                    DataTable tbl = Db.GetDataTable(query);
                    if (tbl.Rows.Count > 0)
                    {
                        if (tbl.Rows[0]["resultid"].ToString() == "1")
                        {
                            result = Common.SuccessMessage(
                                tbl.Rows[0]["resultmessage"].ToString()
                            );
                            result.TargetUUID = tbl.Rows[0]["voyage_uuid"]?.ToString();
                        }
                        else
                        {
                            result = Common.ErrorMessage(
                                tbl.Rows[0]["resultmessage"].ToString()
                            );
                        }
                    }
                    else
                    {
                        result = Common.ErrorMessage("Cannot save voyage");
                    }
                }
            }
            catch (Exception ex)
            {
                RecordException(ex);
                result = Common.ErrorMessage(ex.Message);
            }

            return result;
        }
        public Result AddIntermediatePortToVoyage(VoyageExtendedDTO voyage)
        {
            Result result = new Result();
            try
            {

                var d = voyage.VoyageDetails;

                using (SqlDB Db = new SqlDB(DatabaseCollection.Contrack))
                {
                    var detail = new
                    {
                        voyagedetailid = Common.Decrypt(d.VoyageDetailId.EncryptedValue),
                        portid = Common.Decrypt(d.PortId.EncryptedValue),
                        terminal = d.Terminal,
                        eta = d.ETA.DBFormattedText,
                        etd = d.ETD.DBFormattedText,
                        cutoffdeadline = d.CutoffDeadline.DBFormattedText,
                        arrivalcaptain = d.ArrivalCaptain,
                        departurecaptain = d.DepartureCaptain,
                        sortorder = d.SortOrder
                    };
                    string detailsJson = System.Text.Json.JsonSerializer.Serialize(detail);
                    string query = $@" SELECT * FROM masters.voyage_add_intermediate_port(
                            p_hubid       := '{Common.HubID}',
                            p_voyageid    := '{Common.Decrypt(voyage.VoyageId.EncryptedValue)}',
                            p_detail_json := '{Common.Escape(detailsJson)}',
                            p_userid      := '{Common.LoginID}');";

                    DataTable tbl = Db.GetDataTable(query);
                    if (tbl.Rows.Count > 0)
                    {
                        if (tbl.Rows[0]["resultid"].ToString() == "1")
                        {
                            result = Common.SuccessMessage(tbl.Rows[0]["resultmessage"].ToString());
                            result.TargetUUID = tbl.Rows[0]["new_voyagedetailid"]?.ToString();
                        }
                        else
                        {
                            result = Common.ErrorMessage(tbl.Rows[0]["resultmessage"].ToString());
                        }
                    }
                    else
                    {
                        result = Common.ErrorMessage("Cannot Mark As Arrived");
                    }
                }
            }
            catch (Exception ex)
            {
                RecordException(ex);
                result = Common.ErrorMessage(ex.Message);
            }

            return result;
        }
        public Result MarkAsArrived(VoyageExtendedDTO voyage)
        {
            Result result = new Result();
            try
            {
                var d = voyage.VoyageDetails;
                using (SqlDB Db = new SqlDB(DatabaseCollection.Contrack))
                {
                    var detail = new
                    {
                        voyagedetailid = Common.Decrypt(d.VoyageDetailId.EncryptedValue),
                        ata = d.ATA.Text,
                        arrivalcaptain = d.ArrivalCaptain,
                    };
                    string detailsJson = System.Text.Json.JsonSerializer.Serialize(detail);
                    string query = $@"SELECT * FROM masters.voyage_save_markarrived(
                    p_hubid       := '{Common.HubID}',
                    p_voyageid    := '{Common.Decrypt(voyage.VoyageId.EncryptedValue)}',
                    p_detail_json := '{Common.Escape(detailsJson)}',
                    p_userid      := '{Common.LoginID}');";

                    DataTable tbl = Db.GetDataTable(query);
                    if (tbl.Rows.Count > 0)
                    {
                        if (tbl.Rows[0]["resultid"].ToString() == "1")
                        {
                            result = Common.SuccessMessage(tbl.Rows[0]["resultmessage"].ToString());
                            result.TargetUUID = tbl.Rows[0]["voyagedetailid"]?.ToString();
                        }
                        else
                        {
                            result = Common.ErrorMessage(tbl.Rows[0]["resultmessage"].ToString());
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                RecordException(ex);
                result = Common.ErrorMessage(ex.Message);
            }

            return result;
        }
