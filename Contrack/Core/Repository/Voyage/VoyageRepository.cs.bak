        public Result DeleteVoyageDetail(int voyageDetailId, int voyageId)
        {
            var result = new Result();
            try
            {
                using (SqlDB Db = new SqlDB(DatabaseCollection.Contrack))
                {
                    string query = $@" SELECT * FROM masters.voyage_detail_delete(
                    p_voyageid := {voyageId},
                    p_voyagedetailid := {voyageDetailId},
                    p_hubid := {Common.HubID});";
                    var tbl = Db.GetDataTable(query);
                    if (tbl.Rows.Count > 0)
                    {
                        var resultId = tbl.Rows[0]["resultid"].ToString();
                        var message = tbl.Rows[0]["resultmessage"].ToString();
                        result = resultId == "1" ? Common.SuccessMessage(message) : Common.ErrorMessage(message);
                    }
                    else
                    {
                        result = Common.ErrorMessage("Cannot Delete Voyage");
                    }
                }
            }
            catch (Exception ex)
            {
                result = Common.ErrorMessage(ex.Message);
            }

            return result;
        }

        public VoyageExtendedDTO GetVoyageByDetailID(int voyagedetailId)
        {
            try
            {
                using (SqlDB Db = new SqlDB(DatabaseCollection.Contrack))
                {
                    string query = $@" SELECT * FROM masters.voyage_detail_byid(
                    p_hubid := '{Common.HubID}',
                    p_voyagedetailid := '{voyagedetailId}',
                    p_userid := '{Common.LoginID}');";
                    DataTable tbl = Db.GetDataTable(query);
                    if (tbl.Rows.Count == 0) return null;

                    DataRow row = tbl.Rows[0];

                    var voyage = new VoyageExtendedDTO
                    {
                        VoyageId = new EncryptedData
                        {
                            NumericValue = Common.ToInt(row["voyageid"]),
                            EncryptedValue = Common.Encrypt(Common.ToInt(row["voyageid"]))
                        },
                        VoyageUuid = Common.ToString(row["voyageuuid"]),
                        VoyageNumber = Common.ToString(row["voyagenumber"]),
                        Description = Common.ToString(row["description"]),
                        VesseDetailId = new EncryptedData
                        {
                            NumericValue = Common.ToInt(row["vesseldetailid"]),
                            EncryptedValue = Common.Encrypt(Common.ToInt(row["vesseldetailid"]))
                        },
                        Vesselname = Common.ToString(row["vesselname"]),
                        VoyageDetails = new VoyageDetailDTO()
                    };
                    if (tbl.Columns.Contains("voyagedetailid"))
                    {
                        voyage.VoyageDetails = new VoyageDetailDTO
                        {
                            VoyageDetailId = new EncryptedData
                            {
                                NumericValue = Common.ToInt(row["voyagedetailid"]),
                                EncryptedValue = Common.Encrypt(Common.ToInt(row["voyagedetailid"]))
                            },
                            VoyageId = voyage.VoyageId,
                            PortId = new EncryptedData
                            {
                                NumericValue = Common.ToInt(row["portid"]),
                                EncryptedValue = Common.Encrypt(Common.ToInt(row["portid"]))
                            },
                            portname = Common.ToString(row["portname"]),
                            portcode = Common.ToString(row["portcode"]),
                            CountryId = Common.ToInt(row["countryid"]),
                            CountryName = Common.ToString(row["countryname"]),
                            CountryFlag = Common.ToString(row["flag"]),
                            Terminal = row["terminal"].ToString(),
                            ETA = FormatConvertor.ToDateTimeFormat(Common.ToDateTime(row["eta"])),
                            ETD = FormatConvertor.ToDateTimeFormat(Common.ToDateTime(row["etd"])),
                            ATA = FormatConvertor.ToDateTimeFormat(Common.ToDateTime(row["ata"])),
                            ATD = FormatConvertor.ToDateTimeFormat(Common.ToDateTime(row["atd"])),
                            CutoffDeadline = FormatConvertor.ToDateTimeFormat(Common.ToDateTime(row["cutoffdeadline"])),
                            ArrivalCaptain = row["arrivalcaptain"].ToString(),
                            DepartureCaptain = row["departurecaptain"].ToString(),
                            SortOrder = Common.ToInt(row["sortorder"]),
                            CreatedAt = Common.ToDateTime(row["createdat"])
                        };
                    }

                    return voyage;
                }
            }
            catch (Exception ex)
            {
                RecordException(ex);
                throw;
            }
        }
        public VoyageExtendedDTO GetVoyageById(int voyageId)
        {
            try
            {
                using (SqlDB Db = new SqlDB(DatabaseCollection.Contrack))
                {
                    string query = $@"SELECT * FROM masters.voyage_get_by_id(
                    p_hubid    := {Common.HubID},
                    p_voyageid := {voyageId},
                    p_userid   := {Common.LoginID});";
                    DataTable tbl = Db.GetDataTable(query);
                    if (tbl.Rows.Count == 0) return null;
                    DataRow row = tbl.Rows[0];
                    var voyage = new VoyageExtendedDTO
                    {
                        VoyageId = new EncryptedData
                        {
                            NumericValue = Common.ToInt(row["h_voyageid"]),
                            EncryptedValue = Common.Encrypt(Common.ToInt(row["h_voyageid"]))
                        },
                        VoyageUuid = row["h_voyageuuid"].ToString(),
                        VoyageNumber = row["h_voyagenumber"].ToString(),
                        Description = row["h_description"].ToString(),
                        VesseDetailId = new EncryptedData
                        {
                            NumericValue = Common.ToInt(row["h_vesseldetailid"]),
                            EncryptedValue = Common.Encrypt(Common.ToInt(row["h_vesseldetailid"]))
                        },
                        Vesselname = Common.ToString(row["h_vesselname"])
                    };
                    return voyage;
                }
            }
            catch (Exception ex)
            {
                RecordException(ex);
                throw;
            }
        }      
